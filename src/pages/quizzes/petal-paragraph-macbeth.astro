---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';
---

<BaseLayout
  title="PETAL Paragraph Puzzle — Macbeth"
  description="Practise PETAL paragraph structure by arranging a model Macbeth paragraph in the correct order. An interactive essay writing exercise for English students."
>
  <Header slot="header" />

  <Banner title="PETAL Paragraph Puzzle" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <div class="mb-8 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Essay Writing</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">PETAL Paragraph — Macbeth</h2>
        <p class="mt-3 text-text-muted">Click the sentences in the correct PETAL order to rebuild the paragraph. Use the guide below as a reference.</p>
      </div>

      <!-- PETAL reference -->
      <div class="mb-8 rounded-xl border border-border bg-white p-4 shadow-sm">
        <p class="mb-3 text-xs font-bold uppercase tracking-widest text-text-muted">PETAL Structure</p>
        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-800">P — Point</span>
          <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-bold text-green-800">E — Evidence</span>
          <span class="rounded-full bg-purple-100 px-3 py-1 text-xs font-bold text-purple-800">T — Technique</span>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-bold text-amber-800">A — Analysis</span>
          <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-bold text-orange-800">A/L — Analysis / Link</span>
        </div>
      </div>

      <!-- Available sentences -->
      <div class="mb-8">
        <p class="mb-3 text-xs font-bold uppercase tracking-widest text-text-muted">Available Sentences — click to place</p>
        <div id="available-area" class="flex flex-col gap-3"></div>
      </div>

      <!-- Built paragraph -->
      <div class="mb-6">
        <p class="mb-3 text-xs font-bold uppercase tracking-widest text-text-muted">Your Paragraph</p>
        <div id="paragraph-area" class="flex flex-col gap-3"></div>
      </div>

      <!-- Action buttons -->
      <div id="action-btns" class="flex flex-wrap gap-3">
        <button
          id="undo-btn"
          disabled
          class="rounded-lg border-2 border-border px-5 py-2.5 text-sm font-bold text-text transition-colors hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-40"
        >
          ← Undo Last
        </button>
        <button
          id="restart-btn"
          class="rounded-lg border-2 border-accent px-5 py-2.5 text-sm font-bold text-accent transition-colors hover:bg-accent hover:text-accent-fg"
        >
          ↺ Restart
        </button>
      </div>

      <!-- Results -->
      <div id="results-area" class="mt-6 hidden"></div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  interface Sentence {
    id: number;
    label: string;
    labelFull: string;
    badgeClass: string;
    selectedClass: string;
    text: string;
  }

  const SENTENCES: Sentence[] = [
    {
      id: 0,
      label: 'P',
      labelFull: 'Point',
      badgeClass: 'bg-blue-100 text-blue-800',
      selectedClass: 'border-blue-400 bg-blue-50',
      text: `Shakespeare presents Macbeth's blind ambition as a corrupting force that leads to significant psychological and physical suffering. The tragic hero, Macbeth, is tempted and later utterly consumed by his blind ambition to kill for power and status.`,
    },
    {
      id: 1,
      label: 'E',
      labelFull: 'Evidence',
      badgeClass: 'bg-green-100 text-green-800',
      selectedClass: 'border-green-400 bg-green-50',
      text: `In Act 2, Scene 2, Macbeth's ambition tempts him toward regicide, a temptation that soon consumes him entirely. Prior to the King's death, Macbeth experiences a hallucination of a dagger, asking <em>"Is this a dagger which I see before me, / the handle towards my hand? Come, let me clutch thee"</em>.`,
    },
    {
      id: 2,
      label: 'T',
      labelFull: 'Technique',
      badgeClass: 'bg-purple-100 text-purple-800',
      selectedClass: 'border-purple-400 bg-purple-50',
      text: `Shakespeare's <strong>rhetorical question</strong> and the <strong>personification</strong> of the dagger's <em>"handle"</em> reaching towards him reveal Macbeth's readiness to commit murder, while the <strong>tactile imagery</strong> of <em>"clutching"</em> symbolises his psychological action of grasping for power.`,
    },
    {
      id: 3,
      label: 'A',
      labelFull: 'Analysis',
      badgeClass: 'bg-amber-100 text-amber-800',
      selectedClass: 'border-amber-400 bg-amber-50',
      text: `This moment clearly marks the beginning of his moral collapse, as he consciously chooses to abandon his honour and disrupt the divine order. Macbeth's act of regicide not only violates the natural hierarchy of the Great Chain of Being, a concept deeply embedded in Jacobean ideology, but also signals his distorted perception of reality fuelled by blind ambition. For a Jacobean audience, Macbeth's crime is more than just political treason — it is a spiritual violation, and as such, this may have intensified perceptions of his own moral corruption, resulting in his further mental instability and overwhelming guilt.`,
    },
    {
      id: 4,
      label: 'E',
      labelFull: 'Evidence',
      badgeClass: 'bg-green-100 text-green-800',
      selectedClass: 'border-green-400 bg-green-50',
      text: `This is evident when Macbeth laments, <em>"Will all great Neptune's ocean wash this blood / Clean from my hand?"</em>.`,
    },
    {
      id: 5,
      label: 'T',
      labelFull: 'Technique',
      badgeClass: 'bg-purple-100 text-purple-800',
      selectedClass: 'border-purple-400 bg-purple-50',
      text: `The recurring <strong>motif</strong> of <em>"blood"</em> symbolises his physical and mental guilt, while the <strong>allusion</strong> to <em>"Neptune"</em>, the Roman god of the sea, emphasises the enormity of his psychological torment and his inability to purge his guilty conscience.`,
    },
    {
      id: 6,
      label: 'A/L',
      labelFull: 'Analysis / Link',
      badgeClass: 'bg-orange-100 text-orange-800',
      selectedClass: 'border-orange-400 bg-orange-50',
      text: `Ultimately, through Macbeth's hallucination of the dagger and the haunting image of blood on his hands, Shakespeare explores the devastating consequences of unchecked ambition, portraying a noble hero's descent into psychological torment and physical suffering as he becomes consumed by blind desire.`,
    },
  ];

  const CORRECT_ORDER = [0, 1, 2, 3, 4, 5, 6];
  const SHUFFLED_ORDER = [3, 5, 1, 6, 0, 4, 2];

  let selected: number[] = [];
  let gameOver = false;

  function initPuzzle() {
    selected = [];
    gameOver = false;

    document.getElementById('results-area')!.classList.add('hidden');
    document.getElementById('results-area')!.innerHTML = '';

    render();

    document.getElementById('undo-btn')!.addEventListener('click', () => {
      if (selected.length === 0 || gameOver) return;
      selected.pop();
      render();
    });

    document.getElementById('restart-btn')!.addEventListener('click', initPuzzle);
  }

  function render() {
    renderAvailable();
    renderParagraph();
    updateButtons();
  }

  function renderAvailable() {
    const area = document.getElementById('available-area')!;
    const remaining = SHUFFLED_ORDER.filter(id => !selected.includes(id));

    if (remaining.length === 0) {
      area.innerHTML = `<p class="text-sm text-text-muted text-center py-3">All sentences placed.</p>`;
      return;
    }

    area.innerHTML = remaining.map(id => {
      const s = SENTENCES[id];
      return `
        <button
          data-id="${id}"
          class="sentence-tile w-full rounded-xl border-2 border-border bg-white px-4 py-3 text-left text-sm leading-relaxed text-text transition-all hover:border-primary hover:bg-primary/5"
        >${s.text}</button>
      `;
    }).join('');

    area.querySelectorAll<HTMLButtonElement>('.sentence-tile').forEach(btn => {
      btn.addEventListener('click', () => {
        if (gameOver) return;
        selected.push(parseInt(btn.dataset.id!));
        render();
        if (selected.length === SENTENCES.length) showResults();
      });
    });
  }

  function renderParagraph() {
    const area = document.getElementById('paragraph-area')!;

    if (selected.length === 0) {
      area.innerHTML = `<div class="rounded-xl border-2 border-dashed border-border p-6 text-center text-sm text-text-muted">Your paragraph will appear here as you select sentences above.</div>`;
      return;
    }

    area.innerHTML = selected.map((id, index) => {
      const s = SENTENCES[id];
      const isCorrect = id === CORRECT_ORDER[index];
      return `
        <div class="flex items-start gap-3 rounded-xl border-2 ${isCorrect ? 'border-green-400 bg-green-50' : 'border-red-300 bg-red-50'} p-4">
          <div class="shrink-0 flex flex-col items-center gap-1.5 pt-0.5">
            <span class="flex size-6 items-center justify-center rounded-full ${isCorrect ? 'bg-green-500' : 'bg-red-400'} text-xs font-bold text-white">${index + 1}</span>
            <span class="rounded-full px-2 py-0.5 text-xs font-bold ${s.badgeClass}">${s.label}</span>
            <span class="text-sm">${isCorrect ? '✅' : '❌'}</span>
          </div>
          <p class="flex-1 text-sm leading-relaxed ${isCorrect ? 'text-green-900' : 'text-red-900'}">${s.text}</p>
        </div>
      `;
    }).join('');
  }

  function updateButtons() {
    const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
    undoBtn.disabled = selected.length === 0 || gameOver;
  }

  function showResults() {
    gameOver = true;
    updateButtons();

    const score = selected.filter((id, i) => id === CORRECT_ORDER[i]).length;
    const icon = score === 7 ? '🎉' : score >= 4 ? '👍' : '📚';
    const msg = score === 7
      ? 'Perfect — you have a strong grasp of PETAL structure.'
      : score >= 4
      ? 'Good effort. Review the highlighted sentences and try again.'
      : 'Keep practising — use the PETAL guide above and try again.';

    const resultsArea = document.getElementById('results-area')!;
    resultsArea.classList.remove('hidden');
    resultsArea.innerHTML = `
      <div class="rounded-2xl border border-border bg-white p-6 text-center shadow-sm">
        <div class="mb-3 text-5xl">${icon}</div>
        <p class="font-heading text-2xl font-bold text-text">${score} / 7 correct</p>
        <p class="mt-2 text-text-muted">${msg}</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <button id="results-restart-btn" class="rounded-lg border-2 border-primary px-6 py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg">
            Try Again
          </button>
          <a href="${baseUrl('/quizzes')}" class="rounded-lg bg-accent px-6 py-2.5 text-center text-sm font-bold text-accent-fg transition-opacity hover:opacity-90">
            Back to Quizzes
          </a>
        </div>
      </div>
    `;

    document.getElementById('results-restart-btn')!.addEventListener('click', initPuzzle);
  }

  document.addEventListener('astro:page-load', initPuzzle);
</script>
