---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';

const quizzes = [
  {
    title: 'Society & Culture',
    subtitle: 'HSC Exam Practice — Section I',
    description: 'Multiple-choice questions covering Social and Cultural Continuity and Change. Based on official HSC exam papers.',
    tag: 'HSC',
    href: baseUrl('/subjects/society-and-culture-quiz'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
  },
  {
    title: '1984 — George Orwell',
    subtitle: 'English Advanced — Human Experiences',
    description: 'Multiple-choice questions covering plot, characters, themes and literary techniques in George Orwell\'s 1984.',
    tag: 'English',
    href: baseUrl('/quizzes/1984-quiz'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'The Crucible — Arthur Miller',
    subtitle: 'English Advanced & Standard — Human Experiences',
    description: 'Multiple-choice questions covering plot, characters, themes and literary techniques in Arthur Miller\'s The Crucible.',
    tag: 'English',
    href: baseUrl('/quizzes/the-crucible-quiz'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'T.S. Eliot — Preludes & Rhapsody on a Windy Night',
    subtitle: 'English Advanced — Critical Study of Literature',
    description: 'Multiple-choice questions covering imagery, techniques and analysis in T.S. Eliot\'s Preludes and Rhapsody on a Windy Night.',
    tag: 'English',
    href: baseUrl('/quizzes/ts-eliot-quiz'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
];
---

<BaseLayout
  title="Quizzes"
  description="Free interactive HSC quizzes from Boldtutor. Test your knowledge with multiple-choice questions based on real HSC exams."
>
  <Header slot="header" />

  <Banner title="Quizzes" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <div class="mx-auto mb-12 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Practice</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Interactive HSC Quizzes</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Multiple-choice quizzes based on real HSC exam questions. Instant feedback on every answer.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {quizzes.map(({ title, subtitle, description, tag, href, icon }) => (
          <a
            href={href}
            class="group flex flex-col rounded-2xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-4 flex items-start justify-between">
              <div class="flex size-12 items-center justify-center rounded-xl bg-accent/10 text-accent">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
              </div>
              <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide text-primary">{tag}</span>
            </div>

            <h3 class="font-heading text-xl font-bold uppercase text-text group-hover:text-primary transition-colors">{title}</h3>
            <p class="mt-0.5 text-xs font-semibold text-accent">{subtitle}</p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{description}</p>

            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <span class="text-xs font-semibold text-text-muted">Multiple choice</span>
              <span class="text-xs font-bold text-primary group-hover:underline">Start quiz →</span>
            </div>
          </a>
        ))}

        <!-- Coming soon placeholder -->
        <div class="flex flex-col rounded-2xl border border-dashed border-border bg-surface p-6 opacity-60">
          <div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-border text-text-muted">
            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold uppercase text-text-muted">More Coming Soon</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">English, Modern History, and more HSC quizzes are on the way. Check back regularly — new questions are added from past HSC exams.</p>
        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
