  // --- HSC (most recent first) ---
  {
    title: 'HSC English — Short Answer Practice',
    subtitle: 'English Advanced & Standard — Human Experiences',
    description: 'Practise Paper 1 short answer responses with five unseen texts. Write your response, then reveal and compare with a sample answer.',
    level: 'HSC',
    typeLabel: '2 texts',
    cta: 'Start practice →',
    href: baseUrl('/quizzes/hsc-english-short-answers'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
