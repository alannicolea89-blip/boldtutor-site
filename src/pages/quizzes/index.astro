---

<BaseLayout
  title="Free HSC English Quizzes &amp; Practice Tasks"
  description="Free interactive quizzes and practice tasks for HSC English, Year 9 and Year 8. T.S. Eliot, The Crucible, 1984, Society and Culture and more. Instant feedback."
>
  <Header slot="header" />

  <Banner title="Quizzes & Tasks" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Practice</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Quizzes &amp; Practice Tasks</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Multiple-choice quizzes and creative writing tasks for HSC and Year 9 English. Instant feedback on every answer.
        </p>
      </div>

      <!-- Filter buttons -->
      <div class="mb-8 flex flex-wrap justify-center gap-2">
        <button
          data-filter="all"
          class="filter-btn rounded-full border-2 border-primary bg-primary px-5 py-2 text-sm font-bold text-primary-fg transition-all"
        >All</button>
        <button
          data-filter="HSC"
          class="filter-btn rounded-full border-2 border-border bg-white px-5 py-2 text-sm font-bold text-text transition-all hover:border-primary hover:text-primary"
        >HSC (Years 11–12)</button>
        <button
          data-filter="Year 8"
          class="filter-btn rounded-full border-2 border-border bg-white px-5 py-2 text-sm font-bold text-text transition-all hover:border-primary hover:text-primary"
        >Year 8</button>
        <button
          data-filter="Year 9"
          class="filter-btn rounded-full border-2 border-border bg-white px-5 py-2 text-sm font-bold text-text transition-all hover:border-primary hover:text-primary"
        >Year 9</button>
      </div>

      <div id="quiz-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {quizzes.map(({ title, subtitle, description, level, typeLabel, cta, href, icon }) => (
          <a
            href={href}
            data-level={level}
            class="quiz-card group flex flex-col rounded-2xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-4 flex items-start justify-between">
              <div class="flex size-12 items-center justify-center rounded-xl bg-accent/10 text-accent">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
              </div>
              <span class={`rounded-full px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide ${level === 'Year 9' ? 'bg-accent/10 text-accent' : level === 'Year 8' ? 'bg-green-100 text-green-700' : 'bg-primary/10 text-primary'}`}>
                {level}
              </span>
            </div>

            <h3 class="font-heading text-xl font-bold uppercase text-text transition-colors group-hover:text-primary">{title}</h3>
            <p class="mt-0.5 text-xs font-semibold text-accent">{subtitle}</p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{description}</p>

            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <span class="text-xs font-semibold text-text-muted">{typeLabel}</span>
              <span class="text-xs font-bold text-primary group-hover:underline">{cta}</span>
            </div>
          </a>
        ))}

        <!-- Coming soon placeholder -->
        <div data-level="all" class="quiz-card flex flex-col rounded-2xl border border-dashed border-border bg-surface p-6 opacity-60">
          <div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-border text-text-muted">
            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold uppercase text-text-muted">More Coming Soon</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">More quizzes and tasks for HSC and Year 9 are on the way. Check back regularly.</p>
        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.quiz-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update button styles
      buttons.forEach(b => {
        b.classList.remove('bg-primary', 'text-primary-fg', 'border-primary');
        b.classList.add('bg-white', 'text-text', 'border-border');
      });
      btn.classList.remove('bg-white', 'text-text', 'border-border');
      btn.classList.add('bg-primary', 'text-primary-fg', 'border-primary');

      // Show/hide cards
      cards.forEach(card => {
        const level = card.dataset.level;
        const show = filter === 'all' || level === filter || level === 'all';
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
