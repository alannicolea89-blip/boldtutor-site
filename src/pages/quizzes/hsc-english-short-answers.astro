---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';
---

<BaseLayout
  title="HSC English Short Answer Practice"
  description="Practise HSC English Paper 1 short answer responses with five unseen texts. Write your response, then compare with a sample answer."
>
  <Header slot="header" />
  <Banner title="Short Answer Practice" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <div class="mb-8 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">HSC English</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Short Answer Practice</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Read each text, write your short answer response, then reveal the sample answer to compare.
        </p>
      </div>

      <!-- Progress tabs -->
      <div id="progress-tabs" class="mb-6 flex flex-wrap justify-center gap-2">
        <!-- injected by JS -->
      </div>

      <!-- Main panel -->
      <div id="panel">
        <!-- injected by JS -->
      </div>

      <!-- Navigation -->
      <div class="mt-6 flex items-center justify-between">
        <button id="prev-btn" class="rounded-lg border-2 border-border px-5 py-2.5 text-sm font-bold text-text-muted transition-colors hover:border-primary hover:text-primary disabled:pointer-events-none disabled:opacity-30">
          &larr; Previous
        </button>
        <span id="counter" class="text-sm font-semibold text-text-muted"></span>
        <button id="next-btn" class="rounded-lg border-2 border-primary px-5 py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg disabled:pointer-events-none disabled:opacity-30">
          Next &rarr;
        </button>
      </div>

      <div class="mt-8 rounded-2xl border border-dashed border-border bg-white p-5 text-center">
        <p class="text-sm font-semibold text-text-muted">More texts and questions are being added. Check back soon.</p>
      </div>

      <div class="mt-6 text-center">
        <a href={baseUrl('/quizzes')} class="text-sm font-semibold text-text-muted hover:text-primary">
          &larr; Back to Quizzes
        </a>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
interface TextBlock {
  label: string;
  type: string;
  title: string;
  author: string;
  isPoem: boolean;
  body: string;
}

interface TextItem {
  texts: TextBlock[];
  marks: number;
  question: string;
  sampleAnswer?: string;
  samplePoints?: string[];
  sampleLabel: string;
  isNew?: boolean;
}

const TEXTS: TextItem[] = [

  // ---- 1. Rutsala poem + McPhee fiction (NESA Sample Question 2, Example B, 6 marks) ----
  {
    texts: [
      {
        label: 'Text 2',
        type: 'Poem',
        title: 'Looking in the Album',
        author: 'Vern Rutsala',
        isPoem: true,
        body: `Here the formal times are surrendered
to the camera's indifferent gaze: weddings,
graduations, births and official portraits taken
every ten years to falsify appearances.

Even snapshots meant to gather afternoons
with casual ease are rigid. Smiles
are too buoyant. Tinny laughter echoes
from the staged scene on an artificial
beach. And yet we want to believe
this is how it was: The children's hair
always bore the recent marks of combs;
that trousers, even at picnics, were always
creased and we travelled years with the light
but earnest intimacy of linked hands or arms
arranged over shoulders. This is the record
of our desired life: Pleasant, leisurely on vacations,
wryly comic before local landmarks, competent
auditors of commencement speakers, showing
in our poses that we believed what we were told.

But this history contains no evidence
of aimless nights when the wilderness of ourselves
sprang up to swallow the outposts of what
we thought we were. Nowhere can we see
tears provoked by anything but joy. There
are no pictures of our brittle, lost intentions.
We burned the negatives* that we felt did not give a true
account and with others made this abridgement of our lives.

VERN RUTSALA`,
      },
      {
        label: 'Text 3',
        type: 'Fiction Extract',
        title: 'Other People\'s Words',
        author: 'Hilary McPhee',
        isPoem: false,
        body: `First came her stories like webs across the world. They crisscrossed the Atlantic on steamers and the Rockies by train. They made their way down dirt tracks where the scrub met overhead. They flew from Ben Lomond in the Tasmanian Highlands, which we could see from her verandah, to Welsh farmhouses of dark stone. The air would shiver slightly each time she began.

Once upon a time, when pigs were swine and monkeys chewed tobacco, there was a little girl who lived at the foot of the mountains in the center of the universe at the bottom of the world ...

The storyteller was my grandmother and the child was me. We came to her for stories ... Her stories were vivid and shapely and we heard them again and again. In the night under the pine trees, her house creaked and her stories invaded our dreams. Later I would catch something of their rhythms and word play in ballads and sagas and know what a talented storyteller she was.

Then we took her for granted ...

She was born in 1894, a beloved only child in a family with a little money or the myth of money from her great-great-grandfather, a clergyman, who had invested during the early nineteenth century, surely somewhat dubiously, in Welsh coal mines. Family portraits survive and hang in a Tasmanian dining-room.

I know I should check the facts. There is evidence to be weighed, archives to be searched, family members still alive who knew her differently. There will be shipping lists and parish records, deeds and wills lodged in three countries. The men I will find easily, labelled by their work and their bank balances, the buying and selling of land, and of houses returned to at night. The women will have left less clear a mark on the record but more of a mark on me, perhaps, and on all the children in between. There are some family papers, recipes, photographs and a sampler in black cross-stitch done, my grandmother told me, by a child, my great-great-great great-grandmother, during the Napoleonic wars when children were forbidden to use coloured silks. Or so she said.

There were stories of unfeeling trustees and money withheld and unsuitable marriages when good-looking rogues took advantage of well-to-do widows. She seems to have married an American twenty years her junior after my great grandfather died. This young man went into the city of London every morning at ten but never told his wife what he did there. Perhaps she never asked. When it was discovered that he'd been through all her money, he returned to America, never to be seen again. Or so the story goes ...

The historian at the back of my brain says I should discover what is true and what is false, make a properly considered account before it's too late. The rest of me, the part that was shaped by the sense of myself at the center of the universe at the bottom of the world, still sees, as if through certain cloud formations above paddocks pale with tussocks, the shapes and shadows of other places she made my own.

I want to leave her and her stories be.

Hilary McPhee
Adapted from Other People's Words`,
      },
    ],
    marks: 6,
    question: 'Compare how Text 2 and Text 3 explore the paradoxes in the human experience.',
    sampleLabel: 'NESA Sample Answer',
    sampleAnswer: `The human experience is multifaceted and can often be paradoxical. The response of individuals to the paradoxes of life can be equally unpredictable, given the human desire to understand experiences. Rutsala's evocative poem, 'Looking in the Album', accentuates the challenges of confronting the paradoxical nature of the human experience through the framing device of a photo album which highlights the desire of people to curate their lives in a way that provides a desirable narrative. The passive voice in which 'the formal times are surrendered' to the personified 'indifferent gaze' of the camera highlights the persona's recognition of the desire to control the representation of our experiences.

In contrast to Rutsala's poem, the extract from Other People's Words establishes how the writer embraces the paradoxical and unexplainable nature of life and the qualities of the people who contribute to our lives. McPhee tells the story of her grandmother and the stories she related to them that became an inextricable part of her understanding of the world, shown through the simile of 'first came her stories like webs across the world'. The pervasive nature of these stories is rendered by the extended metaphor through which the stories 'crisscrossed the Atlantic' and 'flew from Ben Lomond'. However, the intertextuality of the beginning of one of the stories, using the 'Once upon a time' archetype, accentuates their unreliability. The metaphor of 'there is evidence to be weighed' echoes the human desire to achieve clarity as established in the poem, and avoid ambiguity in the face of the unreliability of oral stories, as exemplified through the repeated use of qualifiers such as 'or so she said'.`,
  },

  // ---- 2. Pauline Nguyen — Secrets of the Red Lantern (Trial HSC, 4 marks) ----
  {
    texts: [
      {
        label: 'Text 2',
        type: 'Nonfiction Extract',
        title: 'Secrets of the Red Lantern – Stories and Vietnamese Recipes from the Heart',
        author: 'Pauline Nguyen (from the Foreword)',
        isPoem: false,
        body: `In my family, food is our language. Food enables us to communicate the things we find so hard to say.

We escaped Vietnam not long after the fruitless war and spent a difficult year in a Thai refugee camp before arriving in Australia in the late seventies. My brothers and I grew up in Cabramatta during the bleakest of times. Ruled over by our strict, food-obsessed parents, we ran a busy Vietnamese restaurant called Pho Cay Du on the main street—this is where a significant part of our lives unfolded. Both formally trained chefs, my parents were never relaxed about showing tenderness and understanding with us as children. Whether it was out of disinterest or of necessity, they were workaholics who instead poured their knowledge and affection into the food they cooked to feed their children. A strange way to show parental love, but I have grown to accept that this was perhaps the only way they knew.

A dish of bitter melon soup is a dish of reconciliation. When we quarrel, we cannot speak the words "I am sorry" – we give this bittersweet soup instead. In another instance, the sharing of a particular meal can offer the sentiment we each crave to hear: "It's good to see you again – I've missed you." On rare occasions, too few to forget, I have understood the longed-for words, "Please forgive me."

When I think about my father's ca ri de, it is inevitable that I am reminded of Thomas and three of the most embarrassing moments of my life. Thomas was an untouchable. I knew little about him, except that he always looked good and didn't move very much. Often expressionless, without a hair out of place, he worked at Loose Threads, the coolest joint in Cabramatta at the time, selling the latest in street fashion. As an awkward, perpetually frustrated teenager, I liked Thomas as I did no other guy.

Every day after school, it was my job to pick up half a goat for my father's curry. My mother would always insist that I use her painfully impractical and superbly indiscreet shopping cart. Not only was it fluorescent orange, it was also too small to conceal the goat carcass. To top it off, its broken wheel squeaked conspicuously to alert Thomas and his friends of my approach. Every day I had to pass the boy of my dreams while wearing my tentlike private girls' school uniform and pushing a malfunctioning orange contraption on wheels with a hairy goat leg sticking out of it. Sure, I could have taken Railway Parade, turned left at Hughes Street, left again at Park Street through Freedom Plaza and back onto John Street, but with the busted wheel and the extra load, it would have taken three times as long and a firm backhand from my father would have ensued.

PAULINE NGUYEN, LUKE NGUYEN & MARK JENSEN
Secrets of the Red Lantern – Stories and Vietnamese Recipes from the Heart, 2008`,
      },
    ],
    marks: 4,
    question: '"In my family, food is our language. Food enables us to communicate the things we find hard to say."\n\nHow does food represent language for the Nguyen family in Text 2?',
    sampleLabel: 'Sample Answer',
    sampleAnswer: `Food represents language as it allows the family to connect, despite their differences highlighting the importance of shared experiences in the human condition as a means of connection and relation. The use of the collective noun "us" in "food enables us to communicate the things we find hard to say" reinforces the shared nature of food as the language and means of connection within the whole family. This underscores food representing language as the whole family is able to connect through it. The use of metaphor in "workaholics who instead poured their knowledge and affection into the food they cooked" highlights the use of food as the vessel for meaningful connection; food allows the family to connect despite the inability to effectively verbalise their feelings, accentuating it as their family language.`,
  },


  // ---- 3. Richard Flanagan — Quartier 7 (Trial HSC Q3, 4 marks) ----
  {
    texts: [
      {
        label: 'Text 3',
        type: 'Nonfiction Extract',
        title: 'Question 7',
        author: 'Richard Flanagan',
        isPoem: false,
        body: `When I first attempted writing novels as an adult I wrote tales of cities and crowds, the great tropes of European modernism. Every word was rubbish. I'd never seen a city or known a crowd. My first experience of a crowd was in London at the age of twenty-four. I was frightened. It was inconceivable that there could be so many people and not one person knew you nor you them. And there amidst innumerable millions of fellow human beings I felt the most terrible solitude that was also an inconsolable fear. There was no anchor, there were no roots, there was no river down which I might return. All I knew was what I first experienced as a child, unsayable and unwritten, a world within which the measure of things was not man made and of which you existed as a minuscule fragment. Finding words for it was, in one sense, my life's work and my life's failure.

Now that world we oddly disdain as the non-human — as though we are somehow separate of it — is vanishing. And with it, unnoticed, a different, larger way of being human than that propounded by western art and thought. Could it be what is being lost with that world is us?

At some point I came to understand that I wrote from the frontlines of a war about which most have no idea. For a long time I could not understand that it was possible to be both on the side that has the power, that has unleashed the destruction, vast as it is indescribable, and, at the same time, be on the side that loses everything.

To do that you have to return to a child blinking in the rain, staring into the darkness, looking for something that his parents saw only an instant before and which has already vanished for all time, never to return.

That's life.

RICHARD FLANAGAN
From Quartier 7, 2021
Penguin Random House Australia`,
      },
    ],
    marks: 4,
    question: 'Explain what Richard Flanagan comes to realise about life by reflecting on his earlier experiences in Text 3.',
    sampleLabel: 'High Response',
    sampleAnswer: `Flanagan's past individual human experience of fear is successfully conveyed in his extract through communicating his vivid past experiences which had stark impacts on the way he lives life in the present. He illustrates this message through the use of past tense "I was frightened" which partnered with a short sentence and fearful tone alerts the reader that his past human experience was negative. He then uses a tricolon in "there was no anchor, there were no roots, there was no river which I might return". The imagery in this line brings Flanagan to the realisation that sometimes life brings about a feeling of isolation and no way to exit which was highly brought about in his individual experience of writing. This self-reflection is finalised in the last line of the first paragraph through contrast in "my life's work and my life's failure" portraying the unpredictable nature of life — explaining that sometimes what you love to do can also be your downfall — which Flanagan came to realise while exploring the individual human experience of fear.`,
  },

  // ---- 4. Wislawa Szymborska — Possibilities (Trial HSC Q4, 4 marks) ----
  {
    texts: [
      {
        label: 'Text 4',
        type: 'Poem',
        title: 'Possibilities',
        author: 'Wislawa Szymborska',
        isPoem: true,
        body: `I prefer movies.
I prefer cats.
I prefer the oaks along the Warta.
I prefer Dickens to Dostoyevsky.
I prefer myself liking people
to myself loving mankind.
I prefer keeping a needle and thread on hand, just in case.
I prefer the color green.
I prefer not to maintain
that reason is to blame for everything.
I prefer exceptions.
I prefer to leave early.
I prefer talking to doctors about something else.
I prefer the old fine-lined illustrations.
I prefer the absurdity of writing poems
to the absurdity of not writing poems.
I prefer, where love's concerned, nonspecific anniversaries
that can be celebrated every day.
I prefer moralists who promise me nothing.
I prefer cunning kindness to the over-trustful kind.
I prefer the earth in civvies.
I prefer conquered to conquering countries.
I prefer having some reservations.
I prefer the hell of chaos to the hell of order.
I prefer Grimms' fairy tales to the newspapers' front pages.
I prefer leaves without flowers to flowers without leaves.
I prefer dogs with uncropped tails.
I prefer light eyes, since mine are dark.
I prefer desk drawers.
I prefer many things that I haven't mentioned here
to many things I've also left unsaid.
I prefer zeroes on the loose
to those lined up behind a cipher.
I prefer the time of insects to the time of stars.
I prefer to knock on wood.
I prefer not to ask how much longer and when.
I prefer keeping in mind even the possibility
that existence has its own reason for being.

WISLAWA SZYMBORSKA
The Wislawa Szymborska Foundation`,
      },
    ],
    marks: 4,
    question: 'In what ways does the persona convey the value of individuality in Text 4?',
    sampleLabel: 'High Response',
    sampleAnswer: `The persona of Text 4 conveys the strong value of individuality through sharing the experience of preference. The repetition of the statement "I prefer" uses a personal pronoun to convey the persona's unique preferences. The use of "I" conveys that their preferences may be different to other people's, conveying their strong individuality. When the composer makes a comparison — "I prefer myself liking people to myself loving mankind" — they convey the different aspects people can prefer and how they value one over the other. Both of these convey the value of individuality by enabling the reader to understand the persona on a deeper level and make connections of the similarities and differences they have with them, enabling them to reflect on their own individuality.`,
  },


  // ---- 5. Kathleen Williams — Outer Banks (Magazine feature, 5 marks) ----
  {
    texts: [
      {
        label: 'Text 1',
        type: 'Magazine feature article',
        title: 'Outer Banks',
        author: 'Kathleen Williams',
        isPoem: false,
        body: `Six houses collapsed into the ocean on the Outer Banks, a series of islands off North Carolina, between May and November 2024. In this area of the world, strips of houses that were once on solid ground find themselves on sand due to coastal erosion. I discover these houses through TikTok. Their immense, shuddering structures collapsing into the ocean are captivating, seductive. I wonder if it's somehow appealing on a class level, if we're all hiding smirks while watching the upstairs gentry implode from the downstairs quarters. The houses are enormous, teetering on stilts like circus performers staring down the sand. People on stilts are generally horrible, so it's easy to wish the house's demise. Each lapping wave is an invitation for destruction, and if waves are certain to do something, it is lap.

Abandoned houses are naturally imbued with a sense of loss. If personal items have been left behind and the house has been left to rot and decay, it's not for a good reason. The objects that make up a life are hard won, particularly when you love objects for the sake of objects. Typically, these abandoned house images are outliers, framed by financial crisis or political abandonment. Then the environment, which doesn't care one bit about political or financial crises, ties the two together.

On TikTok, I see someone enter one of the abandoned houses on the Outer Banks before it collapses into the ocean. Our voyager does a voiceover for this video. We watch in POV, the cameraman's legs becoming our own, as we head up into the stilted home. Waves crash underfoot and underfloor. The front door opens with no resistance into a house whose form has been distorted by water. Walls and ceilings are missing but with no perceivable logic; a reminder that not only is the water below, but it also around and above and in.

Any abandoned home explorer will tell you that going upstairs is something no-one should do, precisely before they themselves do it. Walking along beams is a preferred trick of the well-initiated, but when a house is swaying into the water, those precautions fall out of favour and the window. We go up another floor again, this one almost roofless; the shell of the house a conduit for water, a temporary island built around the water it carries and briefly resists. The gulf in the ceiling seems to invite water in, challenging the sky to tear the house open from the inside. This is a house intent on destruction, self-sacrifice to the elements. Every extra footstep is outstaying our welcome.

How does a house get remembered? How does it get condemned? Houses such as the few teetering over ocean in the Outer Banks are abandoned before they are destroyed, leaving the wrecking to be done by winds and water, and houses are falling into the ocean with greater frequency because climate change is speeding up coastal erosion and allowing it to cast its net wider. As people walk along the beaches that suspend these homes, they walk along a condemned alley. The coast just as temporary as the house – our new shared timeline.

When the house goes into the ocean, it hasn't been entirely cleared of its content. Junk drawers still hold blunt scissors, a mug sits full of old pens waiting to be tested before being thrown out, outdoor furniture weathers quickly. The reason for leaving a house largely intact is twofold: that clearing it can be dangerous, but mostly that there isn't any money to demolish it. The homeowners certainly aren't going to cough up cash to bring about its ruin prematurely. When the houses collapse into the ocean, so too will the debris of the lives of those who lived there. So too will toxic chemicals, wood, plastics, mattresses, ceramics, plasterboard, insulation, and whatever engineered fabrics and materials make up the skeleton of a home. All of this bursting into the tides and currents, either ending up castaway on an island of garbage with other trash to break down eventually and join the silt at the bottom of the ocean, or to end up on other shorelines, a disembodied offering, sent off to some other place outside of care's shadow. Once it's gone, it was never there.

Kathleen Williams
From Outer Banks, Island Magazine`,
      },
    ],
    marks: 5,
    question: 'Analyse how the writer portrays the relationship between humans and nature.',
    sampleLabel: 'Sample Answer',
    sampleAnswer: `Williams portrays the relationship between humans and nature as one of inevitable conflict, in which nature is indifferent to human concerns and ultimately reclaims what humans have built.

Williams uses personification to portray nature as an active and purposeful force. The description of the wave as "an invitation for destruction" attributes intention to the ocean, positioning it as a willing participant in the demolition of human structures rather than a passive natural force. This is reinforced later when "the gulf in the ceiling seems to invite water in, challenging the sky to tear the house open from the inside," where nature is cast as both invited and aggressive, turning the house's own architecture against it. Through this technique, Williams portrays the relationship between humans and nature as one where nature holds the upper hand.

The simile comparing the houses to "circus performers staring down the sand" further develops this portrayal by emphasising the precariousness of human construction against the permanence of the natural world. Just as a circus performer teetering on stilts is defined by the risk of falling, the houses are defined by their proximity to collapse. The comparison subtly mocks the ambition of human building while suggesting that nature simply waits.

Williams also uses imagery of water's all-encompassing presence to show how completely nature penetrates and distorts human space. The phrase "not only is the water below, but it also around and above and in" positions water as something that has dissolved the logic of the house entirely, occupying every dimension.
Finally, an accumulation of domestic objects — "toxic chemicals, wood, plastics, mattresses, ceramics, plasterboard, insulation" — is used to show how comprehensively nature will consume human life. The list moves from the toxic to the mundane, suggesting that nature makes no distinction between what humans value and what they discard. The terse conclusion, "Once it's gone, it was never there," reinforces this by portraying nature as capable of erasing all evidence of human presence entirely.`,
    isNew: true,
  },

];

// ---- STATE ----
let current = 0;
const revealed: boolean[] = new Array(TEXTS.length).fill(false);
const answers: string[] = new Array(TEXTS.length).fill('');

// ---- ELEMENTS ----
const tabsEl = document.getElementById('progress-tabs')!;
const panelEl = document.getElementById('panel')!;
const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
const counterEl = document.getElementById('counter')!;

// ---- HELPERS ----
function esc(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function wordCount(s: string): number {
  return s.trim() ? s.trim().split(/\s+/).length : 0;
}

function renderTextBlock(tb: { label: string; type: string; title: string; author: string; isPoem: boolean; body: string }): string {
  const content = tb.isPoem
    ? `<pre class="whitespace-pre-wrap font-sans text-sm leading-7 text-text">${esc(tb.body)}</pre>`
    : tb.body.split('\n\n').map(p => `<p class="mb-4 text-sm leading-relaxed text-text last:mb-0">${esc(p)}</p>`).join('');

  return `
    <div class="mb-4 rounded-2xl border border-border bg-white p-6 shadow-sm sm:p-8">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-bold uppercase tracking-wide text-accent">${esc(tb.label)}: ${esc(tb.type)}</span>
      </div>
      <h3 class="font-heading text-xl font-bold text-text">&ldquo;${esc(tb.title)}&rdquo;</h3>
      <p class="mb-5 text-sm font-semibold text-text-muted">${esc(tb.author)}</p>
      <div class="${tb.isPoem ? 'rounded-xl bg-surface p-5' : ''}">${content}</div>
    </div>`;
}

function renderSample(t: TextItem): string {
  if (t.samplePoints) {
    return `<ul class="list-disc pl-5 space-y-2">${t.samplePoints.map(pt => `<li class="text-sm leading-relaxed text-text">${esc(pt)}</li>`).join('')}</ul>`;
  }
  return (t.sampleAnswer ?? '').split('\n\n')
    .map(p => `<p class="mb-3 text-sm leading-relaxed text-text last:mb-0">${esc(p)}</p>`)
    .join('');
}

// ---- RENDER ----
function renderTabs(): void {
  tabsEl.innerHTML = TEXTS.map((t, i) => {
    const active = i === current;
    const done = revealed[i];
    const cls = active
      ? 'border-primary bg-primary text-primary-fg'
      : done
      ? 'border-green-500 bg-green-50 text-green-700'
      : 'border-border bg-white text-text hover:border-primary hover:text-primary';
    const newDot = t.isNew && !done
      ? `<span class="absolute -top-1 -right-1 size-2.5 rounded-full bg-green-500 ring-2 ring-white"></span>`
      : '';
    return `<button data-idx="${i}" class="tab-btn relative size-9 rounded-full border-2 text-sm font-bold transition-all ${cls}">${done ? '&#10003;' : i + 1}${newDot}</button>`;
  }).join('');

  tabsEl.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      current = parseInt(btn.dataset.idx!);
      renderAll();
    });
  });
}

function renderPanel(): void {
  const t = TEXTS[current];
  const sampleVisible = revealed[current] ? '' : 'hidden';

  const textBlocks = t.texts.map(renderTextBlock).join('');

  panelEl.innerHTML = `
    ${textBlocks}

    <div class="mb-4 rounded-2xl border-l-4 border-primary p-6 shadow-sm" style="background: color-mix(in srgb, #1B3A6B 5%, white);">
      <p class="mb-2 text-xs font-bold uppercase tracking-widest text-primary">Question &mdash; ${t.marks} marks</p>
      <p class="text-base font-semibold leading-relaxed text-text">${esc(t.question)}</p>
    </div>

    <div class="mb-4 rounded-2xl border border-border bg-white p-6 shadow-sm">
      <label for="answer-ta" class="mb-2 block text-sm font-bold text-text">Your Response</label>
      <textarea
        id="answer-ta"
        class="w-full resize-y rounded-xl border border-border bg-surface p-4 text-sm leading-relaxed text-text placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
        rows="8"
        placeholder="Write your response here…"
      >${esc(answers[current])}</textarea>
      <div class="mt-3 flex items-center justify-between">
        <span id="wc" class="text-xs text-text-muted">${wordCount(answers[current])} words</span>
        <button id="reveal-btn" class="rounded-lg bg-primary px-5 py-2.5 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90">
          Compare with sample answer
        </button>
      </div>
    </div>

    <div id="sample-block" class="${sampleVisible} rounded-2xl border border-green-200 bg-green-50 p-6 shadow-sm">
      <div class="mb-3 flex items-center justify-between">
        <p class="text-xs font-bold uppercase tracking-widest text-green-700">${esc(t.sampleLabel)}</p>
        <button id="hide-btn" class="text-xs font-semibold text-green-700 hover:underline">Hide</button>
      </div>
      ${renderSample(t)}
    </div>
  `;

  const ta = document.getElementById('answer-ta') as HTMLTextAreaElement;
  const wc = document.getElementById('wc')!;

  ta.addEventListener('input', () => {
    answers[current] = ta.value;
    wc.textContent = `${wordCount(ta.value)} words`;
  });

  document.getElementById('reveal-btn')!.addEventListener('click', () => {
    revealed[current] = true;
    document.getElementById('sample-block')!.classList.remove('hidden');
    renderTabs();
  });

  document.getElementById('hide-btn')?.addEventListener('click', () => {
    document.getElementById('sample-block')!.classList.add('hidden');
  });
}

function renderNav(): void {
  prevBtn.disabled = current === 0;
  nextBtn.disabled = current === TEXTS.length - 1;
  counterEl.textContent = `Text ${current + 1} of ${TEXTS.length}`;
}

function renderAll(): void {
  renderTabs();
  renderPanel();
  renderNav();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

prevBtn.addEventListener('click', () => { if (current > 0) { current--; renderAll(); } });
nextBtn.addEventListener('click', () => { if (current < TEXTS.length - 1) { current++; renderAll(); } });

renderAll();
</script>
