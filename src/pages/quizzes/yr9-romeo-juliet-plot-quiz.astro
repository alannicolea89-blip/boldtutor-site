---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';
---

<BaseLayout
  title="Year 9 Romeo and Juliet Plot Quiz — 20 Questions"
  description="Test your Year 9 knowledge of Shakespeare's Romeo and Juliet with 20 multiple-choice questions focused entirely on plot details. Instant feedback."
>
  <Header slot="header" />

  <Banner title="Romeo and Juliet — Plot Quiz" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <div class="mb-8 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Year 9 English</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Romeo and Juliet — Plot Details</h2>
        <p class="mt-3 text-text-muted">20 questions · Plot details only · Click an option to answer · Instant feedback</p>
      </div>

      <div id="quiz-container">

        <div class="mb-6">
          <div class="mb-2 flex justify-between text-xs font-semibold text-text-muted">
            <span id="progress-label">Question 1 of 20</span>
            <span id="score-label">Score: 0 / 0</span>
          </div>
          <div class="h-2 w-full overflow-hidden rounded-full bg-border">
            <div id="progress-bar" class="h-full rounded-full bg-primary transition-all duration-300" style="width: 0%"></div>
          </div>
        </div>

        <div id="question-card" class="rounded-2xl border border-border bg-white p-6 shadow-sm sm:p-8">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1">
            <span id="q-number" class="text-xs font-bold uppercase tracking-widest text-primary">Q1</span>
          </div>
          <div id="stimulus-box" class="mb-5 hidden rounded-lg border border-border bg-surface p-4 text-sm leading-relaxed text-text-muted"></div>
          <p id="question-text" class="mb-6 text-base font-semibold leading-relaxed text-text sm:text-lg"></p>
          <div id="options-list" class="flex flex-col gap-3"></div>
          <div class="mt-6 flex justify-end">
            <button id="next-btn" class="hidden rounded-lg bg-primary px-6 py-2.5 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90">Next Question →</button>
            <button id="finish-btn" class="hidden rounded-lg bg-accent px-6 py-2.5 text-sm font-bold text-accent-fg transition-opacity hover:opacity-90">See Results</button>
          </div>
        </div>

        <div id="results-card" class="hidden rounded-2xl border border-border bg-white p-8 text-center shadow-sm">
          <div id="results-icon" class="mb-4 text-5xl"></div>
          <h3 class="font-heading text-2xl font-bold uppercase text-text">Quiz Complete</h3>
          <p id="results-score" class="mt-2 text-4xl font-extrabold text-primary"></p>
          <p id="results-message" class="mt-2 text-text-muted"></p>
          <div id="results-breakdown" class="mt-6 space-y-2 text-left"></div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <button id="restart-btn" class="rounded-lg border-2 border-primary px-6 py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg">Try Again</button>
            <a href={baseUrl('/quizzes')} class="rounded-lg bg-accent px-6 py-2.5 text-center text-sm font-bold text-accent-fg transition-opacity hover:opacity-90">Back to Quizzes</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const LABELS = ['A', 'B', 'C', 'D'];

  interface Question {
    text: string;
    stimulus: string | null;
    options: string[];
    answer: number;
  }

  const questions: Question[] = [
    // --- ACT I ---
    {
      text: 'In which city do the events of Romeo and Juliet take place?',
      stimulus: null,
      options: ['Florence', 'Verona', 'Venice', 'Padua'],
      answer: 1,
    },
    {
      text: 'The Chorus introduces two families at the beginning of the play. What word best describes their relationship?',
      stimulus: null,
      options: [
        'Allied — they share business interests in Verona',
        'Feuding — they are bitter rivals and enemies',
        'Indifferent — they largely ignore one another',
        'Related — they are cousins through marriage',
      ],
      answer: 1,
    },
    {
      text: 'What does the Prince of Verona threaten to do to anyone who continues the street fighting?',
      stimulus: null,
      options: [
        'Execute them publicly',
        'Imprison them for life',
        'Banish them from Verona',
        'Force them to pay a heavy fine',
      ],
      answer: 2,
    },
    {
      text: 'Why does Lord Capulet plan a feast at the start of the play?',
      stimulus: null,
      options: [
        'To celebrate a military victory over the Montagues',
        'To introduce his daughter Juliet to Count Paris, who seeks to marry her',
        'To negotiate a peace settlement with the Montague family',
        'To mark Tybalt\'s return to Verona after a long absence',
      ],
      answer: 1,
    },
    {
      text: 'Who are the two friends that attend the Capulet party with Romeo?',
      stimulus: null,
      options: [
        'Tybalt and Paris',
        'Friar Laurence and Balthasar',
        'Benvolio and Mercutio',
        'Paris and Benvolio',
      ],
      answer: 2,
    },
    {
      text: 'How do Romeo and his friends gain entry to the Capulet feast?',
      stimulus: null,
      options: [
        'They are formally invited by Lord Capulet as a peace gesture',
        'They bribe one of the Capulet servants at the gate',
        'They go in disguise',
        'They wait until the party spills into the street',
      ],
      answer: 2,
    },
    {
      text: 'Who does Romeo originally hope to see at the Capulet party?',
      stimulus: null,
      options: ['Juliet', 'The Nurse', 'Lady Capulet', 'Rosaline'],
      answer: 3,
    },
    {
      text: 'Who recognises the Montague boys at the feast and forces them to leave?',
      stimulus: null,
      options: ['Lord Capulet', 'Count Paris', 'Friar Laurence', 'Tybalt'],
      answer: 3,
    },
    // --- ACT II ---
    {
      text: 'After the party, where does Juliet appear when Romeo lingers near the Capulet house?',
      stimulus: null,
      options: [
        'In the garden below',
        'In her window',
        'At the front gate',
        'On the rooftop',
      ],
      answer: 1,
    },
    {
      text: 'What do Romeo and Juliet plan to do the very next day after declaring their love?',
      stimulus: null,
      options: [
        'Elope to the city of Mantua',
        'Write letters to their parents asking for permission to be together',
        'Marry',
        'Meet again in secret at Friar Laurence\'s cell to make plans',
      ],
      answer: 2,
    },
    {
      text: 'Who helps the lovers arrange their secret marriage?',
      stimulus: null,
      options: [
        'Mercutio, who distracts Tybalt',
        'Benvolio, who carries the messages',
        'Juliet\'s Nurse',
        'The Prince\'s chamberlain',
      ],
      answer: 2,
    },
    {
      text: 'Where are Romeo and Juliet secretly married?',
      stimulus: null,
      options: [
        'In the Capulet family garden at midnight',
        'In the streets of Verona during a festival',
        'At the Prince\'s court',
        'At the cell of Friar Laurence',
      ],
      answer: 3,
    },
    {
      text: 'The line "Parting is such sweet sorrow that I shall say goodnight till it be morrow" appears in which Act and Scene?',
      stimulus: '"Parting is such sweet sorrow that I shall say goodnight till it be morrow."',
      options: ['Act 1 Scene 5', 'Act 2 Scene 2', 'Act 3 Scene 1', 'Act 2 Scene 6'],
      answer: 1,
    },
    // --- ACT III ---
    {
      text: 'Following the secret marriage, what does Tybalt send to Romeo?',
      stimulus: null,
      options: [
        'A peace offering on behalf of the Capulet family',
        'A letter warning Romeo to leave Verona',
        'A challenge to fight',
        'A message inviting Romeo to meet Lord Capulet',
      ],
      answer: 2,
    },
    {
      text: 'Romeo refuses to fight Tybalt. This refusal angers his friend Mercutio, who then fights Tybalt instead. Why does Romeo refuse?',
      stimulus: null,
      options: [
        'Romeo is unarmed and knows he will lose',
        'The Prince has just passed a law against duelling',
        'Romeo has secretly married Juliet, making Tybalt family',
        'Benvolio begs Romeo to walk away',
      ],
      answer: 2,
    },
    {
      text: 'How does Mercutio die?',
      stimulus: null,
      options: [
        'Tybalt strikes him directly during the duel',
        'He is accidentally killed as Romeo steps in to stop the fight',
        'He falls from his horse while trying to flee',
        'He is struck by a stray blow from a bystander',
      ],
      answer: 1,
    },
    {
      text: 'What does Romeo do immediately after Mercutio is killed?',
      stimulus: null,
      options: [
        'He flees to Friar Laurence for advice',
        'He reports the death to the Prince',
        'He pursues Tybalt and kills him',
        'He goes to Juliet to say goodbye',
      ],
      answer: 2,
    },
    {
      text: 'What punishment does the Prince give Romeo for killing Tybalt?',
      stimulus: null,
      options: ['Death', 'Imprisonment in Verona', 'Banishment from Verona', 'A public trial'],
      answer: 2,
    },
    {
      text: 'What does Lord Capulet decide while his family is grieving for Tybalt?',
      stimulus: null,
      options: [
        'He challenges Lord Montague to a formal duel to settle the feud',
        'He asks the Prince to spare Romeo\'s life',
        'He moves Juliet\'s wedding to Paris forward to the next day',
        'He sends Juliet to a convent for her own protection',
      ],
      answer: 2,
    },
    // --- ACT IV ---
    {
      text: 'In Act IV, what does Friar Laurence give Juliet, and what does it do?',
      stimulus: null,
      options: [
        'A letter to smuggle to Romeo in Mantua explaining her plan',
        'A sleeping draught that will make her appear dead',
        'A poison to use against Paris on the wedding night',
        'Money and a disguise so she can flee Verona alone',
      ],
      answer: 1,
    },
  ];

  function initQuiz() {
    let currentQ = 0;
    let score = 0;
    let answered = false;
    const userAnswers: (number | null)[] = new Array(questions.length).fill(null);

    const progressBar = document.getElementById('progress-bar') as HTMLElement;
    const progressLabel = document.getElementById('progress-label') as HTMLElement;
    const scoreLabel = document.getElementById('score-label') as HTMLElement;
    const qNumber = document.getElementById('q-number') as HTMLElement;
    const stimulusBox = document.getElementById('stimulus-box') as HTMLElement;
    const questionText = document.getElementById('question-text') as HTMLElement;
    const optionsList = document.getElementById('options-list') as HTMLElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const finishBtn = document.getElementById('finish-btn') as HTMLButtonElement;
    const questionCard = document.getElementById('question-card') as HTMLElement;
    const resultsCard = document.getElementById('results-card') as HTMLElement;
    const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;

    if (!progressBar || !questionText || !optionsList) return;

    function renderQuestion(index: number) {
      answered = false;
      const q = questions[index];
      qNumber.textContent = `Q${index + 1}`;
      questionText.textContent = q.text;

      if (q.stimulus) {
        stimulusBox.classList.remove('hidden');
        stimulusBox.textContent = q.stimulus;
      } else {
        stimulusBox.classList.add('hidden');
        stimulusBox.innerHTML = '';
      }

      optionsList.innerHTML = '';
      q.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = [
          'flex w-full items-start gap-3 rounded-xl border-2 border-border bg-white px-4 py-3',
          'text-left text-sm text-text transition-all',
          'hover:border-primary hover:bg-primary/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary',
        ].join(' ');
        btn.innerHTML = `
          <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-current text-xs font-bold">${LABELS[i]}</span>
          <span>${opt}</span>
        `;
        btn.addEventListener('click', () => handleAnswer(i));
        optionsList.appendChild(btn);
      });

      progressBar.style.width = `${(index / questions.length) * 100}%`;
      progressLabel.textContent = `Question ${index + 1} of ${questions.length}`;
      scoreLabel.textContent = `Score: ${score} / ${index}`;
      nextBtn.classList.add('hidden');
      finishBtn.classList.add('hidden');
    }

    function handleAnswer(selected: number) {
      if (answered) return;
      answered = true;
      userAnswers[currentQ] = selected;

      const q = questions[currentQ];
      const isCorrect = selected === q.answer;
      if (isCorrect) score++;

      const buttons = optionsList.querySelectorAll('button');
      buttons.forEach((btn, i) => {
        btn.classList.remove('hover:border-primary', 'hover:bg-primary/5');
        (btn as HTMLButtonElement).disabled = true;
        if (i === q.answer) {
          btn.classList.add('border-green-500', 'bg-green-50', 'text-green-800');
          const badge = btn.querySelector('span:first-child');
          if (badge) badge.classList.add('border-green-500', 'bg-green-500', 'text-white');
        }
        if (i === selected && !isCorrect) {
          btn.classList.add('border-red-400', 'bg-red-50', 'text-red-800');
          const badge = btn.querySelector('span:first-child');
          if (badge) badge.classList.add('border-red-400', 'bg-red-400', 'text-white');
        }
      });

      scoreLabel.textContent = `Score: ${score} / ${currentQ + 1}`;
      if (currentQ === questions.length - 1) {
        finishBtn.classList.remove('hidden');
      } else {
        nextBtn.classList.remove('hidden');
      }
    }

    function showResults() {
      questionCard.classList.add('hidden');
      resultsCard.classList.remove('hidden');
      progressBar.style.width = '100%';
      progressLabel.textContent = 'Quiz complete';
      scoreLabel.textContent = `Score: ${score} / ${questions.length}`;

      const pct = Math.round((score / questions.length) * 100);
      const icon = pct >= 75 ? '🎉' : pct >= 50 ? '👍' : '📚';
      const msg = pct >= 75
        ? 'Excellent work — strong knowledge of the plot.'
        : pct >= 50
        ? 'Good effort. Review the questions you missed and try again.'
        : 'Keep revising the plot — re-read key scenes and try again.';

      (document.getElementById('results-icon') as HTMLElement).textContent = icon;
      (document.getElementById('results-score') as HTMLElement).textContent = `${score} / ${questions.length}`;
      (document.getElementById('results-message') as HTMLElement).textContent = msg;

      const breakdown = document.getElementById('results-breakdown') as HTMLElement;
      breakdown.innerHTML = '';
      questions.forEach((q, i) => {
        const correct = userAnswers[i] === q.answer;
        const div = document.createElement('div');
        div.className = `flex items-start gap-3 rounded-lg p-3 text-sm ${correct ? 'bg-green-50' : 'bg-red-50'}`;
        div.innerHTML = `
          <span class="mt-0.5 shrink-0 text-base">${correct ? '✅' : '❌'}</span>
          <div>
            <p class="font-semibold ${correct ? 'text-green-800' : 'text-red-800'}">Q${i + 1}. ${q.text}</p>
            ${!correct ? `<p class="mt-0.5 text-red-700">Correct answer: <strong>${LABELS[q.answer]}. ${q.options[q.answer]}</strong></p>` : ''}
          </div>
        `;
        breakdown.appendChild(div);
      });
    }

    nextBtn.addEventListener('click', () => { currentQ++; renderQuestion(currentQ); });
    finishBtn.addEventListener('click', showResults);
    restartBtn.addEventListener('click', () => {
      currentQ = 0; score = 0; userAnswers.fill(null);
      resultsCard.classList.add('hidden');
      questionCard.classList.remove('hidden');
      renderQuestion(0);
    });

    renderQuestion(0);
  }

  document.addEventListener('astro:page-load', initQuiz);
</script>
