---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';
---

<BaseLayout
  title="Romeo and Juliet Quiz — William Shakespeare"
  description="Test your knowledge of Shakespeare's Romeo and Juliet with 25 multiple-choice questions covering the full plot across Acts I to V — five questions per Act. Instant feedback."
>
  <Header slot="header" />

  <Banner title="Romeo and Juliet Quiz" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <div class="mb-8 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Yr 7–10 English</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">William Shakespeare — Romeo and Juliet</h2>
        <p class="mt-3 text-text-muted">25 questions · 5 per Act (I–V) · Click an option to answer · Instant feedback</p>
      </div>

      <div id="quiz-container">

        <div class="mb-6">
          <div class="mb-2 flex justify-between text-xs font-semibold text-text-muted">
            <span id="progress-label">Question 1 of 25</span>
            <span id="score-label">Score: 0 / 0</span>
          </div>
          <div class="h-2 w-full overflow-hidden rounded-full bg-border">
            <div id="progress-bar" class="h-full rounded-full bg-primary transition-all duration-300" style="width: 0%"></div>
          </div>
        </div>

        <div id="question-card" class="rounded-2xl border border-border bg-white p-6 shadow-sm sm:p-8">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1">
            <span id="q-number" class="text-xs font-bold uppercase tracking-widest text-primary">Q1</span>
          </div>
          <div id="stimulus-box" class="mb-5 hidden rounded-lg border border-border bg-surface p-4 text-sm leading-relaxed text-text-muted"></div>
          <p id="question-text" class="mb-6 text-base font-semibold leading-relaxed text-text sm:text-lg"></p>
          <div id="options-list" class="flex flex-col gap-3"></div>
          <div class="mt-6 flex justify-end">
            <button id="next-btn" class="hidden rounded-lg bg-primary px-6 py-2.5 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90">Next Question →</button>
            <button id="finish-btn" class="hidden rounded-lg bg-accent px-6 py-2.5 text-sm font-bold text-accent-fg transition-opacity hover:opacity-90">See Results</button>
          </div>
        </div>

        <div id="results-card" class="hidden rounded-2xl border border-border bg-white p-8 text-center shadow-sm">
          <div id="results-icon" class="mb-4 text-5xl"></div>
          <h3 class="font-heading text-2xl font-bold uppercase text-text">Quiz Complete</h3>
          <p id="results-score" class="mt-2 text-4xl font-extrabold text-primary"></p>
          <p id="results-message" class="mt-2 text-text-muted"></p>
          <div id="results-breakdown" class="mt-6 space-y-2 text-left"></div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <button id="restart-btn" class="rounded-lg border-2 border-primary px-6 py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg">Try Again</button>
            <a href={baseUrl('/quizzes')} class="rounded-lg bg-accent px-6 py-2.5 text-center text-sm font-bold text-accent-fg transition-opacity hover:opacity-90">Back to Quizzes</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const LABELS = ['A', 'B', 'C', 'D'];

  interface Question {
    text: string;
    stimulus: string | null;
    options: string[];
    answer: number;
  }

  const questions: Question[] = [
    // ─────────────── ACT I ───────────────
    {
      text: 'What are the two feuding families in Romeo and Juliet?',
      stimulus: null,
      options: [
        'The Montagues and the Capulets',
        'The Veronas and the Mantuas',
        'The Capulets and the Mercutios',
        'The Montagues and the Parisians',
      ],
      answer: 0,
    },
    {
      text: 'After the opening street brawl, what does the Prince of Verona threaten against anyone who fights again?',
      stimulus: null,
      options: [
        'A heavy fine',
        'Banishment',
        'A public flogging',
        'The loss of their estates',
      ],
      answer: 1,
    },
    {
      text: 'Why does Lord Capulet hold a feast early in the play?',
      stimulus: null,
      options: [
        'To celebrate a victory over the Montagues',
        'To introduce Juliet to Paris, who wishes to marry her',
        'To make peace with the Montague family',
        'To welcome Tybalt back to Verona',
      ],
      answer: 1,
    },
    {
      text: 'Romeo and his friends sneak into the feast in disguise. Who does Romeo originally hope to see there?',
      stimulus: null,
      options: [
        'Juliet',
        'Rosaline',
        'The Nurse',
        'Lady Capulet',
      ],
      answer: 1,
    },
    {
      text: 'Who recognises the disguised Montagues at the feast and forces them to leave?',
      stimulus: null,
      options: [
        'Lord Capulet',
        'Paris',
        'Tybalt',
        'Benvolio',
      ],
      answer: 2,
    },
    // ─────────────── ACT II ───────────────
    {
      text: 'After the feast, where does Juliet appear as Romeo lingers near the Capulet house?',
      stimulus: null,
      options: [
        'At the front gate',
        'At her window',
        'In the garden fountain',
        'On the rooftop',
      ],
      answer: 1,
    },
    {
      text: 'What do Romeo and Juliet declare they will do after confessing their love?',
      stimulus: null,
      options: [
        'Run away to Mantua together',
        'Marry the next day',
        'Ask their parents for permission first',
        'Keep their love a secret forever',
      ],
      answer: 1,
    },
    {
      text: 'Who helps Romeo and Juliet arrange their secret marriage?',
      stimulus: null,
      options: [
        'Mercutio',
        'Benvolio',
        'Juliet\'s Nurse',
        'The Prince',
      ],
      answer: 2,
    },
    {
      text: 'Who secretly marries Romeo and Juliet?',
      stimulus: null,
      options: [
        'The Prince of Verona',
        'Friar Laurence',
        'Lord Montague',
        'An Apothecary',
      ],
      answer: 1,
    },
    {
      text: 'Where does the secret marriage take place?',
      stimulus: null,
      options: [
        'At the Capulet house',
        'In the streets of Verona',
        'At Friar Laurence\'s cell',
        'In Mantua',
      ],
      answer: 2,
    },
    // ─────────────── ACT III ───────────────
    {
      text: 'At the start of Act III, who challenges Romeo to fight — a challenge Romeo refuses?',
      stimulus: null,
      options: [
        'Paris',
        'Tybalt',
        'Benvolio',
        'Lord Capulet',
      ],
      answer: 1,
    },
    {
      text: 'How is Mercutio killed?',
      stimulus: null,
      options: [
        'Tybalt poisons him before the duel',
        'He is accidentally killed as Romeo steps between him and Tybalt',
        'He is executed by the Prince',
        'He dies of grief over Romeo\'s exile',
      ],
      answer: 1,
    },
    {
      text: 'How does Romeo react to Mercutio\'s death?',
      stimulus: null,
      options: [
        'He flees to Mantua at once',
        'He kills Tybalt in anger',
        'He reports Tybalt to the Prince',
        'He challenges Paris to a duel',
      ],
      answer: 1,
    },
    {
      text: 'What punishment does Romeo face for killing Tybalt?',
      stimulus: null,
      options: [
        'Death',
        'Banishment',
        'Imprisonment in Verona',
        'A public trial',
      ],
      answer: 1,
    },
    {
      text: 'How does Lord Capulet respond to the family\'s grief over Tybalt?',
      stimulus: null,
      options: [
        'He calls a truce with the Montagues',
        'He brings Juliet\'s wedding to Paris forward to the next day',
        'He sends Juliet away to a convent',
        'He banishes the Nurse',
      ],
      answer: 1,
    },
    // ─────────────── ACT IV ───────────────
    {
      text: 'To avoid marrying Paris, what does Friar Laurence give Juliet?',
      stimulus: null,
      options: [
        'A letter to take to Romeo',
        'A sleeping draught that makes her appear dead',
        'A real poison',
        'A disguise to flee Verona',
      ],
      answer: 1,
    },
    {
      text: 'What is the potion meant to make everyone believe?',
      stimulus: null,
      options: [
        'That Juliet has run away',
        'That Juliet is dead',
        'That Juliet has fallen ill',
        'That Juliet has already married Romeo',
      ],
      answer: 1,
    },
    {
      text: 'How does Friar Laurence plan to tell Romeo about the scheme?',
      stimulus: null,
      options: [
        'By sending a messenger with a letter to Mantua',
        'By travelling to Mantua himself',
        'By telling Balthasar to pass it on',
        'By leaving a note at the tomb',
      ],
      answer: 0,
    },
    {
      text: 'According to the plan, where is Romeo to collect Juliet when she wakes?',
      stimulus: null,
      options: [
        'Friar Laurence\'s cell',
        'The Capulet family tomb',
        'Juliet\'s bedroom',
        'The gates of Mantua',
      ],
      answer: 1,
    },
    {
      text: 'Why is Juliet willing to take such a dangerous potion?',
      stimulus: null,
      options: [
        'She wants to frighten her parents',
        'She is being forced to marry Paris despite already being married to Romeo',
        'She wishes to escape Verona on her own',
        'She no longer loves Romeo',
      ],
      answer: 1,
    },
    // ─────────────── ACT V ───────────────
    {
      text: 'Why does Friar Laurence\'s message fail to reach Romeo?',
      stimulus: null,
      options: [
        'The messenger is robbed on the road',
        'An outbreak of plague stops the messenger',
        'Romeo has already left Mantua',
        'The letter is lost at sea',
      ],
      answer: 1,
    },
    {
      text: 'Believing Juliet is dead, what does Romeo obtain before returning to Verona?',
      stimulus: null,
      options: [
        'A sword',
        'Poison',
        'A sleeping draught',
        'A fast horse',
      ],
      answer: 1,
    },
    {
      text: 'Whom does Romeo kill at the Capulet tomb?',
      stimulus: null,
      options: [
        'Tybalt',
        'Paris',
        'Friar Laurence',
        'Balthasar',
      ],
      answer: 1,
    },
    {
      text: 'How does Juliet die after waking to find Romeo dead beside her?',
      stimulus: null,
      options: [
        'She drinks poison',
        'She kills herself with Romeo\'s dagger',
        'She dies of grief',
        'She is killed by Paris',
      ],
      answer: 1,
    },
    {
      text: 'What happens between the two families at the end of the play?',
      stimulus: null,
      options: [
        'The feud continues in secret',
        'They reconcile and promise to raise a memorial to the lovers',
        'The Prince exiles both families from Verona',
        'They blame Friar Laurence and imprison him',
      ],
      answer: 1,
    },
  ];

  function initQuiz() {
    let currentQ = 0;
    let score = 0;
    let answered = false;
    const userAnswers: (number | null)[] = new Array(questions.length).fill(null);

    const progressBar = document.getElementById('progress-bar') as HTMLElement;
    const progressLabel = document.getElementById('progress-label') as HTMLElement;
    const scoreLabel = document.getElementById('score-label') as HTMLElement;
    const qNumber = document.getElementById('q-number') as HTMLElement;
    const stimulusBox = document.getElementById('stimulus-box') as HTMLElement;
    const questionText = document.getElementById('question-text') as HTMLElement;
    const optionsList = document.getElementById('options-list') as HTMLElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const finishBtn = document.getElementById('finish-btn') as HTMLButtonElement;
    const questionCard = document.getElementById('question-card') as HTMLElement;
    const resultsCard = document.getElementById('results-card') as HTMLElement;
    const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;

    if (!progressBar || !questionText || !optionsList) return;

    function renderQuestion(index: number) {
      answered = false;
      const q = questions[index];
      qNumber.textContent = `Q${index + 1}`;
      questionText.textContent = q.text;

      if (q.stimulus) {
        stimulusBox.classList.remove('hidden');
        stimulusBox.textContent = q.stimulus;
      } else {
        stimulusBox.classList.add('hidden');
        stimulusBox.innerHTML = '';
      }

      optionsList.innerHTML = '';
      q.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = [
          'flex w-full items-start gap-3 rounded-xl border-2 border-border bg-white px-4 py-3',
          'text-left text-sm text-text transition-all',
          'hover:border-primary hover:bg-primary/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary',
        ].join(' ');
        btn.innerHTML = `
          <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-current text-xs font-bold">${LABELS[i]}</span>
          <span>${opt}</span>
        `;
        btn.addEventListener('click', () => handleAnswer(i));
        optionsList.appendChild(btn);
      });

      progressBar.style.width = `${(index / questions.length) * 100}%`;
      progressLabel.textContent = `Question ${index + 1} of ${questions.length}`;
      scoreLabel.textContent = `Score: ${score} / ${index}`;
      nextBtn.classList.add('hidden');
      finishBtn.classList.add('hidden');
    }

    function handleAnswer(selected: number) {
      if (answered) return;
      answered = true;
      userAnswers[currentQ] = selected;

      const q = questions[currentQ];
      const isCorrect = selected === q.answer;
      if (isCorrect) score++;

      const buttons = optionsList.querySelectorAll('button');
      buttons.forEach((btn, i) => {
        btn.classList.remove('hover:border-primary', 'hover:bg-primary/5');
        (btn as HTMLButtonElement).disabled = true;
        if (i === q.answer) {
          btn.classList.add('border-green-500', 'bg-green-50', 'text-green-800');
          const badge = btn.querySelector('span:first-child');
          if (badge) badge.classList.add('border-green-500', 'bg-green-500', 'text-white');
        }
        if (i === selected && !isCorrect) {
          btn.classList.add('border-red-400', 'bg-red-50', 'text-red-800');
          const badge = btn.querySelector('span:first-child');
          if (badge) badge.classList.add('border-red-400', 'bg-red-400', 'text-white');
        }
      });

      scoreLabel.textContent = `Score: ${score} / ${currentQ + 1}`;
      if (currentQ === questions.length - 1) {
        finishBtn.classList.remove('hidden');
      } else {
        nextBtn.classList.remove('hidden');
      }
    }

    function showResults() {
      questionCard.classList.add('hidden');
      resultsCard.classList.remove('hidden');
      progressBar.style.width = '100%';
      progressLabel.textContent = 'Quiz complete';
      scoreLabel.textContent = `Score: ${score} / ${questions.length}`;

      const pct = Math.round((score / questions.length) * 100);
      const icon = pct >= 75 ? '🎉' : pct >= 50 ? '👍' : '📚';
      const msg = pct >= 75
        ? 'Excellent work — strong exam preparation.'
        : pct >= 50
        ? 'Good effort. Review the questions you missed and try again.'
        : '';

      (document.getElementById('results-icon') as HTMLElement).textContent = icon;
      (document.getElementById('results-score') as HTMLElement).textContent = `${score} / ${questions.length}`;
      (document.getElementById('results-message') as HTMLElement).textContent = msg;

      const breakdown = document.getElementById('results-breakdown') as HTMLElement;
      breakdown.innerHTML = '';
      questions.forEach((q, i) => {
        const correct = userAnswers[i] === q.answer;
        const div = document.createElement('div');
        div.className = `flex items-start gap-3 rounded-lg p-3 text-sm ${correct ? 'bg-green-50' : 'bg-red-50'}`;
        div.innerHTML = `
          <span class="mt-0.5 shrink-0 text-base">${correct ? '✅' : '❌'}</span>
          <div>
            <p class="font-semibold ${correct ? 'text-green-800' : 'text-red-800'}">Q${i + 1}. ${q.text}</p>
            ${!correct ? `<p class="mt-0.5 text-red-700">Correct answer: <strong>${LABELS[q.answer]}. ${q.options[q.answer]}</strong></p>` : ''}
          </div>
        `;
        breakdown.appendChild(div);
      });
    }

    nextBtn.addEventListener('click', () => { currentQ++; renderQuestion(currentQ); });
    finishBtn.addEventListener('click', showResults);
    restartBtn.addEventListener('click', () => {
      currentQ = 0; score = 0; userAnswers.fill(null);
      resultsCard.classList.add('hidden');
      questionCard.classList.remove('hidden');
      renderQuestion(0);
    });

    renderQuestion(0);
  }

  document.addEventListener('astro:page-load', initQuiz);
</script>
