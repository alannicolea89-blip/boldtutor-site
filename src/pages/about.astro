---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import SubjectsGrid from '../components/SubjectsGrid.astro';
import { baseUrl } from '../utils/url';
---

<BaseLayout title="About Us" description="Private English tutor and HSC tutor in Sydney. Boldtutor offers English tutoring, online tutoring, and private English lessons across Glebe, Liverpool, Mortdale, and Western Sydney.">
  <Header slot="header" />

  <Banner title="About Us" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">Private Tutor · Sydney</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Why Boldtutor</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        HSC study can be stressful — a <a href="https://lighthouse.mq.edu.au/article/september-2022/Scaring-Year-12s-about-the-year-ahead-can-backfire-new-study" class="text-primary underline hover:opacity-80">2022 Macquarie University study</a> found that severe stress among HSC students increases from 24% in Term 1 to 31% in Term 3, and that stress tends to rise across Year 12. The right tutor makes all the difference. Boldtutor offers one-on-one guidance, exclusive resources, and dedicated support — so you can study with confidence and achieve the results you're aiming for.
      </p>
      <p class="mt-4 text-text-muted leading-relaxed">
        Booking with Boldtutor also helps support a great cause — <a href="https://www.four-paws.org.au/" class="text-primary underline hover:opacity-80">Four Paws Animal Welfare charity</a>.
      </p>
    </div>
  </section>

  <!-- What I offer -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What I offer</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">My tutoring services</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            title: 'One-on-one sessions',
            desc: 'Private sessions starting from 1 hour — focused entirely on your needs, not a class of students.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />',
          },
          {
            title: 'Your location',
            desc: 'Face-to-face tutoring at your home or a location that suits you across Sydney.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
          },
          {
            title: 'Assignment help',
            desc: 'Feedback and guidance on assignments during your session to help you improve and understand.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
          },
          {
            title: 'Exclusive notes',
            desc: 'Purpose-built resources and notes to deepen your understanding of each topic and subject.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Subjects -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Subjects</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What I teach</h2>
      </div>

      <SubjectsGrid subjects={[
        { title: 'English', description: 'Henry IV · The Tempest · The Crucible · Hag-Seed · Billy Elliot · Craft of Writing · 1984 · And more…', href: baseUrl('/english-services'), icon: 'book' },
        { title: 'University', description: 'Philosophy · Politics · Humanities · Media · Cultural Studies · Journalism · History · Teaching (Secondary)', href: baseUrl('/university-tuition-sydney'), icon: 'graduation' },
        { title: 'Modern History', description: 'History yr 7-11 · Peace and Conflict · Power & Authority in Modern World · National Studies · Change in the Modern World', href: baseUrl('/subjects/modern-history'), icon: 'history' },
        { title: 'Society and Culture', description: 'PIP · Social Theory · Research Methodologies · Depth Studies', href: baseUrl('/subjects/society-and-culture'), icon: 'society' },
      ]} />
    </div>
  </section>

  <!-- Why tuition -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Why tuition</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Why tuition with Boldtutor</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            title: 'Reduce study stress',
            desc: 'Studies show stress levels rise significantly during HSC and tertiary study. Structured one-on-one support helps you stay on top of the work and build real confidence.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
          },
          {
            title: 'Tailored guidance',
            desc: 'Every student learns differently. Sessions are structured around your specific goals, gaps, and upcoming assessments — not a generic curriculum.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
          },
          {
            title: 'Flexible & convenient',
            desc: 'Sessions available face-to-face across Sydney or online via Zoom. Book at a time that fits around school, work, and life.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Book me as your private tutor today"
    description="Ready to start? Message Boldtutor on WhatsApp and book your session."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
