---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout title="Contact Boldtutor" description={`Have a question? Contact ${brand.name} today for private tutoring in Sydney and online.`}>
  <Header slot="header" />

  <Banner title="Contact Us" />

  <section class="py-section">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">

      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Have a question? Contact Boldtutor today</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Your Name, Your Email, and Your Message are all that is required. Please check your junk folder if my response does not reach your inbox.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/success"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Leave this empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Your Name (required) <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Your Email (required) <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Your Message (required) <span class="text-accent" aria-hidden="true">*</span></span>
            <textarea
              name="message"
              rows="5"
              required
              class="min-h-30 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Send
          </button>

          <p class="text-sm text-text-muted">
            You can visit Boldtutor’s <a href="/about" class="font-medium text-primary transition-colors hover:text-primary-light">About</a> page for more info.
          </p>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <aside class="space-y-8 lg:col-span-2">
        <div>
          <h3 class="font-heading text-lg font-semibold text-text">PHONE</h3>
          <a href={`tel:${client.phoneForTel}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.phoneFormatted} – I can chat on Whatsapp
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">EMAIL</h3>
          <a href={`mailto:${client.email}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.email}
          </a>
          <p class="mt-2 text-sm text-text-muted">Please check junk folder if my response does not reach your inbox.</p>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Sydney and Online</h3>
          <p class="mt-1 text-text-muted">
            Private tutoring sessions available across Sydney and online. Call, email, or send a Whatsapp message to book.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
