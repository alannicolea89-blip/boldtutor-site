---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';

const description = 'Professional English tutoring for Years 7-11 in Sydney and online. Personalised support for reading, writing, comprehension, essays, and exam preparation.';

const englishReviews = [
  {
    name: 'Souha Abuelnaga',
    rating: 5,
    quote: "I had the pleasure of working with Alan as my kids tutor and I couldn't be more grateful for the experience. His depth of knowledge, patience, and ability to explain concepts in a great manner is truly amazing. He helped my son develop great skills in spelling and reading and improve his English learning to a high level. Alan also helped my daughter in year 6 improve her understanding in creative writing, plan writing, reading and understanding topic materials.",
  },
  {
    name: 'Revathy Pitchumani',
    rating: 5,
    quote: 'Alan has assisted my son with year 11 and HSC English and has always delivered. Alan\'s teaching ability as well as his resources have helped my son achieve consistently high results. Highly recommended!',
  },
  {
    name: 'Denis',
    rating: 5,
    quote: 'An incredible 5-star tutor. Alan at Infinity Tutoring Mortdale helped my grades improve from 60% to 80%+ thanks to his help and expertise in English. He is patient, knowledgeable, and knows exactly how to push a student to the next level. If you\'re looking to see results and great progress in your marks, Alan at Infinity Tutoring Mortdale is the person to go to.',
  },
];

const coverage = [
  {
    title: 'Reading & Comprehension',
    desc: 'Build deeper comprehension, vocabulary, and confidence with unseen texts, prose, and poetry using practical strategies students can apply at school.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'Essay Writing',
    desc: 'Improve structure, argument development, and evidence integration so students write clearer, stronger essays for school assessments and exams.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
  },
  {
    title: 'Creative Writing',
    desc: 'Develop planning, language control, and narrative technique to produce richer and more coherent creative responses.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h8m-8 4h6M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />',
  },
  {
    title: 'School Exam Prep',
    desc: 'Prepare for class tests and end-of-term exams with focused revision, targeted practice, and feedback on weak areas.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-11 9h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z" />',
  },
];

const advantages = [
  {
    title: 'One-on-One Focus',
    desc: 'Each session is tailored to student level, school requirements, and pace so progress is consistent and measurable.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />',
  },
  {
    title: 'Sydney or Online',
    desc: 'Lessons available at your preferred location in Sydney or online, with flexible scheduling around school timetables.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
  },
  {
    title: 'Practical Feedback',
    desc: 'Students get clear, specific feedback after each task so they know what to improve and how to improve it.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  },
];
---

<BaseLayout title="English Tutor (Yr 7-11)" description={description}>
  <Header slot="header" />

  <Banner title="English Tutor (Yr 7-11)" />

  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">High School Tutoring</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">English Years 7-11</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        Years 7-11 English builds the foundation for Year 12 success. Sessions focus on reading,
        writing, and analysis skills with structured guidance that helps students gain confidence and
        improve classroom performance.
      </p>

      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $65 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $55 / hr online</span>
      </div>

      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What we cover</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">English tutoring services</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {coverage.map(({ title, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Why Boldtutor</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What sets us apart</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {advantages.map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <a
          href="https://www.google.com/search?q=boldtutor+reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 transition-opacity hover:opacity-80"
          aria-label="See all BoldTutor Google reviews"
        >
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Google Reviews</h2>
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {englishReviews.map(({ name, rating, quote }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">
              &ldquo;{quote}&rdquo;
            </blockquote>

            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
                  {name.charAt(0)}
                </div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-section bg-surface" data-instagram-section>
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">On Instagram</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media m-0! w-full! min-w-0!"
            data-instgrm-permalink="https://www.instagram.com/p/DXnKhZhk1xH/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media m-0! w-full! min-w-0!"
            data-instgrm-permalink="https://www.instagram.com/p/DWnqExniUlA/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media m-0! w-full! min-w-0!"
            data-instgrm-permalink="https://www.instagram.com/p/DN4VHafk7g2/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Book your English session today"
    description="Need help with English in Years 7-11? Book on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>

<script>
  function loadInstagramEmbed() {
    const ig = (window as any).instgrm;
    if (ig) {
      ig.Embeds.process();
    } else if (!document.getElementById('instagram-embed-js')) {
      const s = document.createElement('script');
      s.id = 'instagram-embed-js';
      s.async = true;
      s.src = 'https://www.instagram.com/embed.js';
      document.body.appendChild(s);
    }
  }

  function initLazyInstagram() {
    const section = document.querySelector('[data-instagram-section]');
    if (!section) return;
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          loadInstagramEmbed();
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );
    observer.observe(section);
  }

  initLazyInstagram();
  document.addEventListener('astro:after-swap', initLazyInstagram);
</script>
