---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';

const plans = [
  {
    title: 'English',
    subtitle: 'Primary school, years 7–12 & Learn English',
    facePrice: 70,
    onlinePrice: 55,
    featured: true,
    badge: 'Most Popular',
    features: [
      'Primary school English (Yr 3–6)',
      'High school English (Yr 7–11)',
      'HSC English Advanced, Standard & Extension',
      'NAPLAN preparation',
      'Learn English (all levels)',
      'Bilingual support (Spanish)',
    ],
    ctaLabel: 'Book a session',
    ctaHref: 'https://wa.me/61416419270',
  },
  {
    title: 'Society & Culture',
    subtitle: 'HSC Society & Culture',
    facePrice: 80,
    onlinePrice: 65,
    featured: false,
    features: [
      'PIP guidance and resources',
      'Social Theory',
      'Research Methodologies',
      'Depth Studies',
      'HSC exam preparation',
      'Personalised sessions',
    ],
    ctaLabel: 'Book a session',
    ctaHref: 'https://wa.me/61416419270',
  },
  {
    title: 'Modern History',
    subtitle: 'HSC Modern History & years 7–10',
    facePrice: 70,
    onlinePrice: 60,
    featured: false,
    features: [
      'Modern History HSC essay writing',
      'Source analysis',
      'HSC exam preparation',
      'History years 7–10',
      'Personalised sessions',
    ],
    ctaLabel: 'Book a session',
    ctaHref: 'https://wa.me/61416419270',
  },
];

const socOptions = [
  {
    title: 'HSC Exam Preparation',
    price: '$65 / hr online · from $80 / hr in-person',
    description: 'Structured prep for Sections I, II, and III of the HSC Society and Culture exam.',
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'Yr 11 Assignment Help',
    price: '$75 / hr online · from $90 / hr in-person',
    description: 'Support for Year 11 assessment tasks, research methods, and social theory writing.',
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'PIP Support (Yr 12)',
    price: '$95 / hr online · from $110 / hr in-person',
    description: 'Specialist support for the Personal Interest Project — topic, methodology, writing, and editing.',
    href: baseUrl('/subjects/society-and-culture'),
  },
];

const englishOptions = [
  {
    title: 'Primary School – Yr 10',
    price: '$55 / hr online · from $70 / hr in-person',
    description: 'NAPLAN, selective school prep, reading, writing, and high school English for Years 3–10.',
    href: baseUrl('/prices/english-yr7-11'),
  },
  {
    title: 'HSC English – Yr 11',
    price: '$65 / hr online · from $80 / hr in-person',
    description: 'Common Module, Modules A, B, C — essay coaching, text analysis, and trial preparation.',
    href: baseUrl('/prices/hsc-english'),
  },
  {
    title: 'HSC English – Yr 12',
    price: '$75 / hr online · from $90 / hr in-person',
    description: 'Personalised guidance for HSC English Advanced, Standard, and Extension. Exam preparation.',
    href: baseUrl('/prices/hsc-english'),
  },
  {
    title: 'Learn English',
    price: '$50 / hr online · from $60 / hr in-person',
    description: 'Speak, write, and read English with a bilingual tutor (Spanish). All levels welcome.',
    href: baseUrl('/prices/learn-english'),
  },
];
---

<BaseLayout
  title="Prices & Offers"
  description="Boldtutor tutoring prices in Sydney. English from $55/hr online (tiered by year level), Society &amp; Culture from $65/hr online (tiered by service type), Modern History from $60/hr. No lock-in deposits."
>
  <Header slot="header" />

  <Banner title="Prices & Offers" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <!-- Section header -->
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Tutoring rates</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Simple, transparent pricing</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Private one-on-one sessions at your location in Sydney or online. No lock-in term deposits — pay only for the sessions you book.
        </p>
      </div>

      <!-- In-person vs online legend -->
      <div class="mb-10 flex justify-center gap-6 text-sm text-text-muted">
        <span class="flex items-center gap-2">
          <span class="inline-block size-3 rounded-full bg-primary"></span>
          In-person (Sydney)
        </span>
        <span class="flex items-center gap-2">
          <span class="inline-block size-3 rounded-full bg-accent"></span>
          Online / Zoom
        </span>
      </div>

      <!-- Main pricing cards -->
      <div class="grid gap-8 lg:grid-cols-3 lg:items-stretch">
        {plans.map(({ title, subtitle, facePrice, onlinePrice, featured, badge, features, ctaLabel, ctaHref }) => (
          <div class:list={[
            'relative flex flex-col rounded-2xl border p-8 shadow-sm',
            featured
              ? 'border-primary bg-white shadow-primary/10 shadow-lg ring-2 ring-primary'
              : 'border-border bg-white',
          ]}>

            {badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-block rounded-full bg-primary px-4 py-1 text-xs font-bold uppercase tracking-widest text-primary-fg">
                  {badge}
                </span>
              </div>
            )}

            <!-- Title & subtitle -->
            <div class="mb-6">
              <h3 class="font-heading text-2xl font-bold text-text">{title}</h3>
              <p class="mt-1 text-sm text-text-muted">{subtitle}</p>
            </div>

            <!-- Pricing -->
            <div class="mb-6 space-y-2">
              <div class="flex items-baseline gap-1.5">
                <span class="inline-block size-3 shrink-0 rounded-full bg-primary"></span>
                <span class="text-sm text-text-muted">from</span>
                <span class="text-4xl font-extrabold text-text">${facePrice}</span>
                <span class="text-sm text-text-muted">/ hr &nbsp;in-person</span>
              </div>
              <div class="flex items-baseline gap-1.5">
                <span class="inline-block size-3 shrink-0 rounded-full bg-accent"></span>
                <span class="text-sm text-text-muted">from</span>
                <span class="text-4xl font-extrabold text-text">${onlinePrice}</span>
                <span class="text-sm text-text-muted">/ hr &nbsp;online</span>
              </div>
            </div>

            <hr class="border-border mb-6" />

            <!-- Features -->
            <ul class="mb-8 flex-1 space-y-3">
              {features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-text-muted">
                  <svg class="mt-0.5 size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={ctaHref}
              class:list={[
                'block w-full rounded-lg py-3 text-center text-sm font-bold transition-colors',
                featured
                  ? 'bg-primary text-primary-fg hover:opacity-90'
                  : 'border-2 border-primary text-primary hover:bg-primary hover:text-primary-fg',
              ]}
            >
              {ctaLabel}
            </a>

          </div>
        ))}
      </div>

      <!-- English sub-options -->
      <div class="mt-16">
        <h2 class="mb-2 font-heading text-xl font-bold uppercase text-text">English session options</h2>
        <p class="mb-6 text-sm text-text-muted">English rates vary by year level — prices shown are per hour.</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {englishOptions.map(({ title, price, description, href }) => (
            <a
              href={href}
              class="group flex flex-col rounded-xl border border-border bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
            >
              <h3 class="font-heading text-base font-bold text-text group-hover:text-primary transition-colors">{title}</h3>
              <p class="mt-1 text-xs font-semibold text-accent">{price}</p>
              <p class="mt-2 flex-1 text-xs leading-relaxed text-text-muted">{description}</p>
              <span class="mt-4 text-xs font-semibold text-primary group-hover:underline">Find out more →</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Society & Culture sub-options -->
      <div class="mt-12">
        <h2 class="mb-2 font-heading text-xl font-bold uppercase text-text">Society &amp; Culture session options</h2>
        <p class="mb-6 text-sm text-text-muted">Society &amp; Culture rates vary by service type — prices shown are per hour.</p>
        <div class="grid gap-4 sm:grid-cols-3">
          {socOptions.map(({ title, price, description, href }) => (
            <a
              href={href}
              class="group flex flex-col rounded-xl border border-border bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
            >
              <h3 class="font-heading text-base font-bold text-text group-hover:text-primary transition-colors">{title}</h3>
              <p class="mt-1 text-xs font-semibold text-accent">{price}</p>
              <p class="mt-2 flex-1 text-xs leading-relaxed text-text-muted">{description}</p>
              <span class="mt-4 text-xs font-semibold text-primary group-hover:underline">Find out more →</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Free trial CTA -->
  <section class="bg-primary py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6 text-center">
      <h2 class="font-heading text-h2 font-bold uppercase text-primary-fg">Start with a free 1-hour session</h2>
      <p class="mt-3 text-primary-fg/80">No commitment. See how Boldtutor can help before you pay anything.</p>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-8 py-3 text-base font-bold text-primary transition-opacity hover:opacity-90"
      >
        Book your free session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
