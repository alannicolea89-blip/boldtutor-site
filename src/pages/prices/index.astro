---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { baseUrl } from '../../utils/url';

const mhFeatures = [
  'Modern History HSC essay writing',
  'Source analysis',
  'HSC exam preparation',
  'History years 7–10',
  'Personalised sessions',
];

const socOptions = [
  {
    title: 'HSC Exam Preparation',
    price: '$65 / hr online · from $80 / hr in-person',
    description: 'Structured prep for Sections I, II, and III of the HSC Society and Culture exam.',
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'Yr 11 Assignment Help',
    price: '$75 / hr online · from $90 / hr in-person',
    description: 'Support for Year 11 assessment tasks, research methods, and social theory writing.',
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'PIP Support (Yr 12)',
    price: '$95 / hr online · from $110 / hr in-person',
    description: 'Specialist support for the Personal Interest Project — topic, methodology, writing, and editing.',
    href: baseUrl('/subjects/society-and-culture'),
  },
];

const englishOptions = [
  {
    title: 'Primary School (Yr 3–6)',
    price: '$55 / hr online · from $70 / hr in-person',
    description: 'NAPLAN, selective school readiness, reading comprehension, and writing.',
    href: baseUrl('/subjects/primary-school-english'),
  },
  {
    title: 'High School (Yr 7–10)',
    price: '$55 / hr online · from $70 / hr in-person',
    description: 'Essay skills, comprehension, creative writing, and school assessment preparation.',
    href: baseUrl('/prices/english-yr7-11'),
  },
  {
    title: 'HSC English – Yr 11',
    price: '$65 / hr online · from $80 / hr in-person',
    description: 'Common Module, Modules A, B, C — essay coaching, text analysis, and trial preparation.',
    href: baseUrl('/prices/hsc-english'),
  },
  {
    title: 'HSC English – Yr 12',
    price: '$75 / hr online · from $90 / hr in-person',
    description: 'Personalised guidance for HSC English Advanced, Standard, and Extension. Exam preparation.',
    href: baseUrl('/prices/hsc-english'),
  },
  {
    title: 'Learn English',
    price: '$50 / hr online · from $60 / hr in-person',
    description: 'Speak, write, and read English with a bilingual tutor (Spanish). All levels welcome.',
    href: baseUrl('/prices/learn-english'),
  },
];
---

<BaseLayout
  title="Prices & Offers"
  description="Boldtutor tutoring prices in Sydney. English from $55/hr online (tiered by year level), Society &amp; Culture from $65/hr online (tiered by service type), Modern History from $60/hr. No lock-in deposits."
>
  <Header slot="header" />

  <Banner title="Prices & Offers" />

  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <!-- Section header -->
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Tutoring rates</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Simple, transparent pricing</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Private one-on-one sessions at your location in Sydney or online. No lock-in term deposits — pay only for the sessions you book.
        </p>
      </div>

      <!-- ── ENGLISH ────────────────────────────────────────── -->
      <div class="rounded-xl border border-border bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h2 class="font-heading text-xl font-bold uppercase text-text">English</h2>
              <span class="rounded-full bg-primary px-3 py-0.5 text-xs font-bold uppercase tracking-widest text-primary-fg">Most Popular</span>
            </div>
            <p class="mt-1 text-sm text-text-muted">One-on-one in-person (Sydney) or online — rates vary by year level.</p>
          </div>
          <a
            href="https://wa.me/61416419270"
            class="w-full shrink-0 self-start rounded-lg border-2 border-primary px-5 py-2.5 text-center text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg sm:w-auto sm:text-left"
          >
            Book a session
          </a>
        </div>
        <div class="mt-5 divide-y divide-border">
          {englishOptions.map(({ title, price, description, href }) => (
            <div class="flex flex-col gap-1.5 py-4 sm:flex-row sm:items-center sm:gap-4">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-text">{title}</p>
                <p class="mt-0.5 text-xs leading-snug text-text-muted">{description}</p>
              </div>
              <div class="shrink-0 sm:text-right">
                <p class="text-sm font-bold text-accent">{price}</p>
                <a href={href} class="mt-0.5 inline-block text-xs font-semibold text-primary hover:underline">Find out more →</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── SOCIETY & CULTURE ────────────────────────────────── -->
      <div class="mt-8 rounded-xl border border-border bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h2 class="font-heading text-xl font-bold uppercase text-text">Society &amp; Culture</h2>
            <p class="mt-1 text-sm text-text-muted">HSC Society &amp; Culture — rates vary by service type.</p>
          </div>
          <a
            href="https://wa.me/61416419270"
            class="w-full shrink-0 self-start rounded-lg border-2 border-primary px-5 py-2.5 text-center text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg sm:w-auto sm:text-left"
          >
            Book a session
          </a>
        </div>
        <div class="mt-5 divide-y divide-border">
          {socOptions.map(({ title, price, description, href }) => (
            <div class="flex flex-col gap-1.5 py-4 sm:flex-row sm:items-center sm:gap-4">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-text">{title}</p>
                <p class="mt-0.5 text-xs leading-snug text-text-muted">{description}</p>
              </div>
              <div class="shrink-0 sm:text-right">
                <p class="text-sm font-bold text-accent">{price}</p>
                <a href={href} class="mt-0.5 inline-block text-xs font-semibold text-primary hover:underline">Find out more →</a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── MODERN HISTORY ──────────────────────────────────── -->
      <div class="mt-8">
        <div class="mb-5">
          <h2 class="font-heading text-xl font-bold uppercase text-text">Modern History</h2>
          <p class="mt-1 text-sm text-text-muted">HSC Modern History &amp; Years 7–10 — one rate covers all year levels.</p>
        </div>
        <div class="rounded-xl border border-border bg-white p-6 shadow-sm">
          <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
            <!-- Prices -->
            <div class="shrink-0 space-y-2">
              <div class="flex items-baseline gap-1.5">
                <span class="inline-block size-3 shrink-0 rounded-full bg-primary"></span>
                <span class="text-sm text-text-muted">from</span>
                <span class="text-4xl font-extrabold text-text">$70</span>
                <span class="text-sm text-text-muted">/ hr &nbsp;in-person</span>
              </div>
              <div class="flex items-baseline gap-1.5">
                <span class="inline-block size-3 shrink-0 rounded-full bg-accent"></span>
                <span class="text-sm text-text-muted">from</span>
                <span class="text-4xl font-extrabold text-text">$60</span>
                <span class="text-sm text-text-muted">/ hr &nbsp;online</span>
              </div>
            </div>
            <!-- Features -->
            <ul class="flex-1 space-y-2 sm:border-l sm:border-border sm:pl-6">
              {mhFeatures.map((f) => (
                <li class="flex items-start gap-3 text-sm text-text-muted">
                  <svg class="mt-0.5 size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <!-- CTA -->
            <a
              href="https://wa.me/61416419270"
              class="shrink-0 self-start rounded-lg border-2 border-primary px-5 py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg"
            >
              Book a session
            </a>
          </div>
        </div>
      </div>

      <!-- Family pricing callout -->
      <div class="mt-12 flex flex-col items-center justify-between gap-4 rounded-xl border border-accent/20 bg-accent/5 px-6 py-5 sm:flex-row">
        <div>
          <p class="font-semibold text-text">Tutoring more than one child?</p>
          <p class="mt-1 text-sm text-text-muted">Family pricing is available for households with two or more students enrolled in tutoring. Contact us on WhatsApp to discuss a tailored rate.</p>
        </div>
        <a
          href="https://wa.me/61416419270"
          class="shrink-0 inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-bold text-accent-fg transition-opacity hover:opacity-90"
        >
          Message us on WhatsApp
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

    </div>
  </section>

  <!-- Free trial CTA -->
  <section class="bg-primary py-16">
    <div class="mx-auto max-w-site px-4 sm:px-6 text-center">
      <h2 class="font-heading text-h2 font-bold uppercase text-primary-fg">Start with a free 1-hour session</h2>
      <p class="mt-3 text-primary-fg/80">No commitment. See how Boldtutor can help before you pay anything.</p>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-8 py-3 text-base font-bold text-primary transition-opacity hover:opacity-90"
      >
        Book your free session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
