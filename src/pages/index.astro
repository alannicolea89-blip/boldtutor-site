---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import StudentResults from '../components/StudentResults.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { baseUrl } from '../utils/url';
---

<BaseLayout
  title={brand.name}
  description={brand.description}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: client.name,
    telephone: client.phoneForTel,
    email: client.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: client.address.lineOne,
      addressLocality: client.address.city,
      addressRegion: client.address.state,
      postalCode: client.address.zip,
      addressCountry: client.address.country,
    },
    url: client.domain,
  }}
>
  <Header slot="header" />

  <Hero
    topper="Private Tutor Sessions in Sydney"
    heading="Ace HSC and university with Boldtutor"
    description="Personalised support for English, Society & Culture, and Modern History. Sessions start from 1 hour, with face to face and online options."
    ctaLabel="Book Your free 1hr Session Now"
    ctaHref="https://wa.me/61416419270"
    secondaryLabel="View Subjects"
    secondaryHref={baseUrl('/subjects')}
    imageSrc={baseUrl('/legacy-media/2020/07/IMG_0139-1024x765-min.jpg')}
    imageAlt="English literature books and study materials for HSC tutoring"
  />

  <TrustBar items={[
    { label: 'From $55', value: 'Online' },
    { label: 'From $65', value: 'Face to Face' },
    { label: 'Session Lengths', value: '1hr+' },
    { label: 'Sydney Tutoring' },
  ]} />

  <Services
    topper="Subjects"
    heading="Study support tailored for you"
    description="Choose your subject and get personalised sessions focused on exam preparation, writing, and coursework outcomes."
    services={[
      {
        title: 'English',
        description: '',
        points: [
          'From $65 per hour for face to face/$55 for online',
          'Personalised sessions for you',
          'HSC essay writing',
          'HSC exam preparation',
          'Learn English language',
          'Yr K-10 English',
          'NAPLAN',
          'English Extension',
        ],
        icon: 'book',
        backgroundImage: baseUrl('/english-subject-tile.jpg'),
        href: baseUrl('/english-services'),
      },
      {
        title: 'Society & Culture',
        description: '',
        points: [
          'From $80 per hour face to face/$75 for online',
          'PIP',
          'Personalised sessions for you',
          'HSC exam preparation',
          'Social Theory',
          'Research Methodologies',
          'Depth Studies',
        ],
        icon: 'society',
        backgroundImage: baseUrl('/society-subject-tile.jpg'),
        href: baseUrl('/subjects/society-and-culture'),
      },
      {
        title: 'Modern History',
        description: '',
        points: [
          'From $70 per hour for face to face/ $60 for online',
          'Modern History HSC essay writing',
          'Personalised sessions for you',
          'HSC exam preparation',
          'Source analysis',
          'History yr 7-10',
        ],
        icon: 'history',
        backgroundImage: baseUrl('/history-subject-tile.jpg'),
        href: baseUrl('/subjects/modern-history'),
      },
    ]}
  />

  <About
    topper="Why Boldtutor?"
    heading="Private tutor support that reduces stress and builds confidence"
    body={[
      'Firstly, high school work and the year 12 HSC course may result in increased stress levels for high school students according to a 2019 study from Macquarie University.',
      'With this in mind, an effective approach to deal with this stress is to consider hiring me as your high school tutor or HSC tutor from Boldtutor. This is because I offer exclusive resources and dedicated guidance to help you understand how to write an essay among other tasks.',
    ]}
    benefits={[
      'Private tutor sessions starting from 1 hour',
      'Sydney tutoring at your desired location',
      'Exclusive resources and dedicated guidance',
      'Support for Four Paws Animal Welfare charity',
    ]}
    ctaLabel="Read About Boldtutor"
    ctaHref={baseUrl('/about')}
    imageSrc={baseUrl('/society-subject-tile.jpg')}
    imageAlt="Study materials for senior school tutoring and exam preparation"
  />

  <StudentResults
    ctaLabel="Book Your free 1hr Session Now"
    ctaHref="https://wa.me/61416419270"
  />

  <CTA
    title="Book your session today"
    description="Ready to start? Message Boldtutor on WhatsApp and book your first session today."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
