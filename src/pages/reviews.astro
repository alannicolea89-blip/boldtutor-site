---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Student Results" description="View Boldtutor student results, snapshots of success, and then book your session today.">
  <Header slot="header" />

  <Banner title="Student Results" />

  <section class="py-section pb-0">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="font-heading text-h2 font-bold uppercase text-text">Samples of success</h2>
      <p class="mt-4 leading-relaxed text-text-muted">
        Scroll through examples and outcomes, then contact Boldtutor to book your session today.
      </p>
    </div>
  </section>

  <Gallery
    topper="Student Results"
    heading="Snapshots of success"
    description="Examples and outcomes from Boldtutor students across English, university, Society & Culture, and Modern History."
    ctaLabel="Contact Us"
    ctaHref="/contact"
  />

  <CTA
    title="Book your session today"
    description="Need help with assessments, essay writing, or exam preparation? Contact Boldtutor today."
    buttonText="Contact Boldtutor"
    buttonHref="/contact"
  />

  <Footer slot="footer" />
</BaseLayout>
