---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
import { baseUrl } from '../utils/url';
---

<BaseLayout title="Student Results" description="Real results from Boldtutor students — HSC English, Society and Culture, Modern History and more. See what private tutoring in Sydney achieves.">
  <Header slot="header" />

  <Banner title="Student Results" />

  <section class="py-section pb-0">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="font-heading text-h2 font-bold uppercase text-text">Samples of success</h2>
      <p class="mt-4 leading-relaxed text-text-muted">
        Scroll through examples and outcomes, then contact Boldtutor to book your session today.
      </p>
    </div>
  </section>

  <Gallery
    topper="Student Results"
    heading="Snapshots of success"
    description="Examples and outcomes from Boldtutor students across English, university, Society & Culture, and Modern History."
    ctaLabel="Book Your free 1hr Session Now"
    ctaHref="https://wa.me/61416419270"
  />

  <CTA
    title="Book your session today"
    description="Need help with assessments, essay writing, or exam preparation? Book on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
