---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';
import { brand } from '../../config/brand';
import { baseUrl } from '../../utils/url';

function deriveSubject(tags: string[]): string {
  const t = tags.map(s => s.toLowerCase());
  if (t.includes('society and culture')) return 'Society & Culture';
if (t.includes('hsc') && t.some(s => s.includes('english'))) return 'English HSC';
  return 'Other';
}

const collectionPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = collectionPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    href: baseUrl(`/blog/${post.id}`),
    subject: deriveSubject(post.data.tags ?? []),
  }));
---

<BaseLayout title="HSC Study Guides &amp; Resources" description="HSC English study guides, Society and Culture tips, and free resources from Boldtutor — your private tutor in Sydney.">
  <Header slot="header" />

  <Banner title="Blog" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">

      <!-- Filter buttons -->
      <div class="mb-8 flex flex-wrap justify-center gap-2">
        <button
          data-filter="all"
          class="filter-btn rounded-full border-2 border-primary bg-primary px-5 py-2 text-sm font-bold text-primary-fg transition-all"
        >All</button>
        <button
          data-filter="English HSC"
          class="filter-btn rounded-full border-2 border-border bg-white px-5 py-2 text-sm font-bold text-text transition-all hover:border-primary hover:text-primary"
        >English HSC</button>
<button
          data-filter="Society &amp; Culture"
          class="filter-btn rounded-full border-2 border-border bg-white px-5 py-2 text-sm font-bold text-text transition-all hover:border-primary hover:text-primary"
        >Society &amp; Culture</button>
      </div>

      {posts.length === 0 ? (
        <p class="text-center text-text-muted">No posts yet — check back soon.</p>
      ) : (
        <div id="blog-grid" class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map(({ title, description, date, href, subject }) => {
            const formattedDate = date.getFullYear().toString();
            return (
              <article data-subject={subject} class="blog-card group relative flex flex-col overflow-hidden rounded-xl border border-border bg-background shadow-sm transition-shadow hover:shadow-md">
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex items-center justify-between">
                    <time class="text-xs font-medium uppercase tracking-widest text-accent" datetime={date.toISOString()}>
                      {formattedDate}
                    </time>
                    <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-bold text-primary">{subject}</span>
                  </div>
                  <h2 class="mt-3 font-heading text-h3 font-semibold text-text transition-colors group-hover:text-primary">
                    <a href={href} class="after:absolute after:inset-0">
                      {title}
                    </a>
                  </h2>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
                    {description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
                    Read more
                    <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA
    title="Need help with a subject?"
    description="Book tutoring support in Sydney or online via WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      buttons.forEach(b => {
        b.classList.remove('bg-primary', 'text-primary-fg', 'border-primary');
        b.classList.add('bg-white', 'text-text', 'border-border');
      });
      btn.classList.remove('bg-white', 'text-text', 'border-border');
      btn.classList.add('bg-primary', 'text-primary-fg', 'border-primary');

      cards.forEach(card => {
        const subject = card.dataset.subject;
        const show = filter === 'all' || subject === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
