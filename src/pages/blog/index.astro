---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';
import { brand } from '../../config/brand';
import { baseUrl } from '../../utils/url';

const collectionPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = collectionPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    href: baseUrl(`/blog/${post.id}`),
  }));
---

<BaseLayout title="Blog" description={`Study tips, HSC guides, and resources from ${brand.name}.`}>
  <Header slot="header" />

  <Banner title="Blog" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      {posts.length === 0 ? (
        <p class="text-center text-text-muted">No posts yet — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map(({ title, description, date, href }) => {
            const formattedDate = date.getFullYear().toString();
            return (
              <article class="group relative flex flex-col overflow-hidden rounded-xl border border-border bg-background shadow-sm transition-shadow hover:shadow-md">
                <div class="flex flex-1 flex-col p-6">
                  <time class="text-xs font-medium uppercase tracking-widest text-accent" datetime={date.toISOString()}>
                    {formattedDate}
                  </time>
                  <h2 class="mt-3 font-heading text-h3 font-semibold text-text transition-colors group-hover:text-primary">
                    <a href={href} class="after:absolute after:inset-0">
                      {title}
                    </a>
                  </h2>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
                    {description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
                    Read more
                    <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA
    title="Need help with a subject?"
    description="Book tutoring support in Sydney or online via WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
