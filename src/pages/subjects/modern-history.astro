---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';

const description = 'Private Modern History tutor in Sydney and online. HSC essay writing, source analysis, Power & Authority, National Studies and Peace & Conflict. Glebe, Liverpool, Mortdale and Western Sydney.';
---

<BaseLayout title="Modern History Tutor Sydney" description={description}>
  <Header slot="header" />

  <Banner title="Modern History" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">HSC Tutoring</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Modern History</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        The Modern History HSC syllabus can be difficult to grasp given the breadth of source analysis and essay topics students need to master. As your private tutor, I provide the exclusive resources and one-on-one guidance you need to ace the exam with confidence.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $70 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $60 / hr online</span>
      </div>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- What we cover -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What we cover</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Modern History services</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Power & Authority 1919–41',
            desc: 'Studying dictatorships, World War I, or the Nazis can be challenging. I provide the resources and guidance you need to understand the key themes and ace this section of the exam.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />',
          },
          {
            title: 'National Studies',
            desc: 'Covering modern histories of nations such as Australia, China, Japan, and the USA. I help you understand the key ideas and information vital to succeeding in this section.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
          },
          {
            title: 'Peace & Conflict / Change in Modern World',
            desc: 'The final sections require strong extended essay responses and source analysis. I offer targeted resources and writing guidance to keep your analysis sharp for these high-value questions.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Topics covered -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Topics covered</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">History topics I've taught</h2>
      </div>

      <div class="mx-auto max-w-2xl">
        <ul class="grid gap-3 sm:grid-cols-2">
          {[
            'The Cold War',
            'Nazi Germany',
            'Weimar Republic',
            'WW1 & WW2',
            'Peace and Conflict in the Modern World',
            'The Nuclear Age',
            'Indochina',
            'Civil Rights USA',
            'The Modern World and Australia',
            'History Yr 7–11',
          ].map((topic) => (
            <li class="flex items-center gap-3 rounded-lg border border-border bg-white px-4 py-3 text-sm text-text shadow-sm">
              <svg class="size-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {topic}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Why Boldtutor -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Why Boldtutor</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What sets us apart</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            title: 'One-on-one sessions',
            desc: 'Every student has a unique set of challenges. Individual sessions ensure you get targeted support — not a one-size-fits-all approach.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />',
          },
          {
            title: 'Your location or online',
            desc: 'I travel to your home or any location across Sydney. Online sessions available too — flexible scheduling designed around your life.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
          },
          {
            title: 'Essay & source analysis focus',
            desc: 'Comprehension of historical topics, essay writing, and source analysis are the core concerns students face. I address all three with dedicated resources and structured guidance.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Book your session today"
    description="Need help with Modern History? Book on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
