---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';
import { reviewRatingSchema } from '../../utils/reviewSchema';

const title = 'Primary School English Tutor Sydney — Years 3 to 6';
const description = 'Private English tutoring for primary school students in Years 3 to 6, Sydney. NAPLAN preparation, selective school test readiness, reading comprehension, creative writing, spelling and grammar. Face-to-face in Sydney and online Australia-wide.';

// Real Google reviews shown in the "What parents say" section below. Kept in
// frontmatter so the visible cards and the JSON-LD review markup stay identical.
const parentReviews = [
  {
    name: 'Souha',
    rating: 5,
    quote: 'I had the pleasure of working with Alan as my kids tutor and I couldn\'t be more grateful for the experience. His depth of knowledge, patience, and ability to explain concepts in a great manner is truly amazing. He helped my son develop great skills in spelling and reading and improve his English learning to a high level. Alan also helped my daughter in year 6 improve her understanding in creative writing, plan writing, reading and understanding topic materials.',
  },
  {
    name: 'Charli',
    rating: 5,
    quote: 'Alan is a fantastic tutor for all schooling ages, especially with high school. He guided me through my high school English journey, especially during the times when I was struggling. I recommend no one else — highly recommended!',
  },
  {
    name: 'Denis',
    rating: 5,
    quote: 'An incredible 5-star tutor. Alan helped my grades improve from 60% to 80%+ thanks to his help and expertise in English. He is patient, knowledgeable, and knows exactly how to push a student to the next level.',
  },
];

const skills = [
  {
    title: 'NAPLAN Preparation',
    desc: 'Targeted practice across all NAPLAN English strands — reading comprehension, persuasive writing, and language conventions — so students approach test day with confidence and a clear strategy.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />',
  },
  {
    title: 'Selective School Tests',
    desc: 'Preparation for selective high school entrance exams including reading comprehension, writing tasks, and the English components of general ability assessments — starting early makes a significant difference.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
  },
  {
    title: 'Reading Comprehension',
    desc: 'Build the ability to read closely, identify key ideas, infer meaning, and answer comprehension questions accurately — skills that underpin all English study from primary school onward.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'Writing Activities',
    desc: 'Structured writing tasks including narratives, recounts, information texts, and persuasive writing — with clear feedback on planning, structure, and language use after every task.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h8m-8 4h6M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />',
  },
  {
    title: 'Spelling & Grammar',
    desc: 'Systematic spelling practice, punctuation rules, and grammar foundations so students develop accuracy and confidence in their written expression — exactly what NAPLAN markers reward.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  },
  {
    title: 'High School Readiness',
    desc: 'For Year 5 and 6 students, sessions progressively build the analytical reading and structured writing skills that make the transition to high school English significantly smoother.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />',
  },
];

const yearLevels = [
  {
    year: 'Year 3',
    focus: 'First NAPLAN year',
    points: [
      'Reading comprehension with short texts',
      'Narrative and recount writing',
      'Spelling patterns and sight words',
      'Basic punctuation and sentence structure',
      'NAPLAN reading and language conventions practice',
    ],
  },
  {
    year: 'Year 4',
    focus: 'Building core skills',
    points: [
      'Extended comprehension with longer passages',
      'Persuasive writing introduction',
      'Vocabulary building and word families',
      'Grammar: nouns, verbs, adjectives, adverbs',
      'Structured paragraph writing',
    ],
  },
  {
    year: 'Year 5',
    focus: 'NAPLAN & selective prep',
    points: [
      'NAPLAN Year 5 intensive preparation',
      'Selective school English component practice',
      'Analytical reading — inferring, evaluating, synthesising',
      'Multi-paragraph writing with clear structure',
      'Editing and proofreading techniques',
    ],
  },
  {
    year: 'Year 6',
    focus: 'High school transition',
    points: [
      'Selective school test full preparation',
      'Advanced comprehension and critical thinking',
      'Creative writing — planning, drafting, refining',
      'Essay structure foundations',
      'High school English readiness skills',
    ],
  },
];

const advantages = [
  {
    title: 'One-on-One sessions',
    desc: 'Every primary school student learns differently. Private sessions ensure individual attention, feedback tailored to your child\'s exact needs, and a pace set by them — not a classroom.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />',
  },
  {
    title: 'Sydney or online',
    desc: 'Face-to-face sessions at your home in Sydney — including Glebe, Liverpool, Mortdale, and Western Sydney. Online tutoring is available every day of the week for families across Australia.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
  },
  {
    title: 'Proven results',
    desc: 'Students consistently improve their marks, confidence, and writing ability with structured, practical support. From NAPLAN preparation to selective school readiness, I help every student reach their potential.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />',
  },
];

const faqs = [
  {
    question: 'Do you offer English tutoring for primary school students in Sydney?',
    answer: 'Yes. I tutor primary school students from Year 3 to Year 6 across Sydney. Face-to-face sessions are available at your home or a convenient location in Glebe, Liverpool, Mortdale, Western Sydney, and surrounding areas. Online tutoring is also available every day of the week for families anywhere in Australia.',
  },
  {
    question: 'What does a typical primary school English session cover?',
    answer: 'Sessions are structured around your child\'s specific needs and goals. A typical session might include a reading comprehension activity with direct feedback, a writing task (narrative, persuasive, or recount), spelling and grammar practice, and review of any school work or upcoming assessments. Every session builds on the last so progress is consistent and measurable.',
  },
  {
    question: 'When should my child start NAPLAN preparation?',
    answer: 'NAPLAN is sat in Years 3, 5, 7, and 9. Ideally, students begin preparation 8 to 12 weeks before the test. However, building strong reading comprehension and writing skills year-round through regular tutoring produces better outcomes than last-minute preparation. Starting in Year 3 or 4 gives students a significant advantage by the time the test arrives.',
  },
  {
    question: 'Do you help with selective high school test preparation?',
    answer: 'Yes. Selective school test preparation is a key part of what I offer for Year 5 and Year 6 students. Sessions focus on reading comprehension strategies, extended writing tasks, and the English component of general ability sections. The earlier students begin preparing, the more comfortable and confident they become with the format and demands of the test.',
  },
  {
    question: 'How much does primary school English tutoring cost?',
    answer: 'Face-to-face sessions start from $70 per hour and online sessions from $55 per hour. The first session is free — it gives us the chance to assess where your child is, what they need to work on, and what a regular session plan should look like.',
  },
  {
    question: 'Can you help if my child is struggling with reading or writing at school?',
    answer: 'Absolutely. Students who are falling behind at school benefit enormously from one-on-one sessions where they can ask questions freely, work at their own pace, and receive patient, clear instruction. I identify exactly where gaps exist and address them directly with structured, practical activities — not generic worksheets.',
  },
  {
    question: 'Do you offer discounts for families with more than one child?',
    answer: 'Yes. Family pricing is available for households with two or more students enrolled in tutoring. Sessions can cover different year levels and subjects — for example, a primary school student and a high school or HSC sibling. Get in touch via WhatsApp to discuss a tailored rate.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': ['LocalBusiness', 'EducationalOrganization'],
        name: 'Boldtutor',
        telephone: '+61416419270',
        email: 'contact@boldtutor.com.au',
        url: 'https://boldtutor.com.au',
        description: 'Private English tutoring for primary school students in Years 3 to 6. NAPLAN preparation, selective school readiness, reading comprehension, and creative writing.',
        areaServed: [
          { '@type': 'City', name: 'Sydney' },
          { '@type': 'City', name: 'Glebe' },
          { '@type': 'City', name: 'Liverpool' },
          { '@type': 'City', name: 'Mortdale' },
        ],
      },
      {
        '@type': 'Course',
        name: 'Primary School English Tutoring (Years 3–6)',
        description: description,
        provider: { '@type': 'Organization', name: 'Boldtutor', url: 'https://boldtutor.com.au' },
        areaServed: 'Sydney',
        ...reviewRatingSchema(parentReviews),
      },
      {
        '@type': 'FAQPage',
        mainEntity: faqs.map(({ question, answer }) => ({
          '@type': 'Question',
          name: question,
          acceptedAnswer: { '@type': 'Answer', text: answer },
        })),
      },
    ],
  }}
>
  <Header slot="header" />

  <Banner title="Primary School English Tutor" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">Years 3–6 · Private Tutoring</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Primary School English</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        One-on-one English tutoring for primary school students from Year 3 to Year 6 in Sydney and online. Whether your child needs NAPLAN preparation, selective school test support, help with reading and comprehension, or simply wants to build confidence in their writing, sessions are structured around their specific needs and school requirements.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $70 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $55 / hr online</span>
        <span class="text-border">·</span>
        <span>Free first session</span>
      </div>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- What we cover -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What we cover</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Primary school English skills</h2>
        <p class="mt-3 text-text-muted leading-relaxed">Sessions for Years 3 to 6 focus on the core literacy skills children need to succeed at school, in NAPLAN, and in the transition to high school English.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {skills.map(({ title, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Year-by-year breakdown -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Year by year</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What each year level covers</h2>
        <p class="mt-3 text-text-muted leading-relaxed">Sessions are tailored to each student's year level, school curriculum, and individual goals. Here is what a typical programme looks like at each stage.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {yearLevels.map(({ year, focus, points }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3">
              <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary">{year}</span>
              <p class="mt-2 text-xs font-semibold uppercase tracking-wide text-accent">{focus}</p>
            </div>
            <ul class="mt-2 flex flex-col gap-2">
              {points.map(point => (
                <li class="flex items-start gap-2 text-sm text-text-muted">
                  <svg class="mt-0.5 size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {point}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Boldtutor -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Why Boldtutor</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What sets us apart</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {advantages.map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-6 flex items-center gap-3">
        <a
          href="https://www.google.com/search?q=boldtutor+reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 transition-opacity hover:opacity-80"
          aria-label="See all BoldTutor Google reviews"
        >
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">What parents say</h2>
          <span class="mt-0.5 block text-xs text-text-muted">5.0 ★ average — view all on Google ↗</span>
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {parentReviews.map(({ name, quote, rating }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">
              &ldquo;{quote}&rdquo;
            </blockquote>
            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
                  {name.charAt(0)}
                </div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="mb-10 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">FAQ</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Common questions</h2>
      </div>

      <div class="space-y-4" itemscope itemtype="https://schema.org/FAQPage">
        {faqs.map(({ question, answer }) => (
          <details
            class="group rounded-xl border border-border bg-white shadow-sm"
            itemscope
            itemprop="mainEntity"
            itemtype="https://schema.org/Question"
          >
            <summary
              class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 text-sm font-semibold text-text marker:hidden [&::-webkit-details-marker]:hidden"
              itemprop="name"
            >
              {question}
              <svg
                class="size-5 shrink-0 text-primary transition-transform group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div
              class="px-6 pb-5 pt-1 text-sm leading-relaxed text-text-muted"
              itemscope
              itemprop="acceptedAnswer"
              itemtype="https://schema.org/Answer"
            >
              <span itemprop="text">{answer}</span>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Book your child's first free session"
    description="Ready to get started? Message Boldtutor on WhatsApp to book a free one-hour session for your child."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
