---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import Services from '../../components/Services.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';

const subjects = [
  {
    title: 'English',
    description: '',
    points: [
      'From $65/hr face to face · $55/hr online',
      'HSC essay writing',
      'HSC exam preparation',
      'Learn English language',
      'Yr K-10 English',
      'NAPLAN',
      'English Extension',
    ],
    icon: 'book',
    backgroundImage: baseUrl('/english-subject-tile.jpg'),
    href: baseUrl('/english-services'),
  },
  {
    title: 'Society & Culture',
    description: '',
    points: [
      'From $80/hr face to face · $75/hr online',
      'PIP guidance and resources',
      'Personalised sessions for you',
      'HSC exam preparation',
      'Social Theory',
      'Research Methodologies',
      'Depth Studies',
    ],
    icon: 'society',
    backgroundImage: baseUrl('/society-subject-tile.jpg'),
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'Modern History',
    description: '',
    points: [
      'From $70/hr face to face · $60/hr online',
      'Modern History HSC essay writing',
      'Personalised sessions for you',
      'HSC exam preparation',
      'Source analysis',
      'History yr 7-10',
    ],
    icon: 'history',
    backgroundImage: baseUrl('/history-subject-tile.jpg'),
    href: baseUrl('/subjects/modern-history'),
  },
] satisfies Array<{
  title: string;
  description: string;
  points: string[];
  icon: 'book' | 'history' | 'society';
  backgroundImage?: string;
  href: string;
}>;
---

<BaseLayout title="Subjects" description="Explore Boldtutor subjects for English, university tuition, Society & Culture, and Modern History support in Sydney and online.">
  <Header slot="header" />

  <Banner title="Subjects" />

  <Services
    topper="Subjects"
    heading="Find out what I can do for you"
    description="Choose your subject and find the tutoring support, exam preparation, and assignment guidance that fits your needs."
    services={subjects}
  />

  <CTA
    title="Have a question? Contact Boldtutor today"
    description="Book your session or ask about subject availability, online tutoring, and Sydney locations."
    buttonText="Contact Boldtutor"
    buttonHref={baseUrl('/contact')}
  />

  <Footer slot="footer" />
</BaseLayout>
