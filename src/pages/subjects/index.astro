---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import Services from '../../components/Services.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';

const subjects = [
  {
    title: 'English',
    description: '',
    points: [
      'From $65/hr face to face · $55/hr online',
      'HSC essay writing',
      'HSC exam preparation',
      'Learn English language',
      'Yr K-10 English',
      'NAPLAN',
      'English Extension',
    ],
    icon: 'book',
    backgroundImage: baseUrl('/english-subject-tile.jpg'),
    href: baseUrl('/english-services'),
  },
  {
    title: 'Society & Culture',
    description: '',
    points: [
      'From $80/hr face to face · $75/hr online',
      'PIP guidance and resources',
      'Personalised sessions for you',
      'HSC exam preparation',
      'Social Theory',
      'Research Methodologies',
      'Depth Studies',
    ],
    icon: 'society',
    backgroundImage: baseUrl('/society-subject-tile.jpg'),
    href: baseUrl('/subjects/society-and-culture'),
  },
  {
    title: 'Modern History',
    description: '',
    points: [
      'From $70/hr face to face · $60/hr online',
      'Modern History HSC essay writing',
      'Personalised sessions for you',
      'HSC exam preparation',
      'Source analysis',
      'History yr 7-10',
    ],
    icon: 'history',
    backgroundImage: baseUrl('/history-subject-tile.jpg'),
    href: baseUrl('/subjects/modern-history'),
  },
] satisfies Array<{
  title: string;
  description: string;
  points: string[];
  icon: 'book' | 'history' | 'society';
  backgroundImage?: string;
  href: string;
}>;
---

<BaseLayout title="HSC Tutoring Subjects Sydney" description="Explore Boldtutor's tutoring subjects: HSC English Advanced, Standard and Extension, Society and Culture (PIP), Modern History and university humanities. Sydney and online.">
  <Header slot="header" />

  <Banner title="Subjects" />

  <Services
    topper="Subjects"
    heading="Find out what I can do for you"
    description="Choose your subject and find the tutoring support, exam preparation, and assignment guidance that fits your needs."
    services={subjects}
  />

  <!-- HSC English course pages -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">HSC English</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">English courses</h2>
        <p class="mt-3 text-text-muted leading-relaxed">Dedicated tutoring pages for every HSC English course, with module breakdowns, prescribed text resources, and free study guides.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            title: 'English Advanced',
            desc: 'Four modules: Common Module, Module A Textual Conversations, Module B Critical Study, Module C Craft of Writing. Essay coaching, prescribed text analysis, and exam preparation.',
            href: baseUrl('/subjects/english-advanced'),
            badge: 'HSC',
          },
          {
            title: 'English Standard',
            desc: 'Four modules: Common Module, Module A Language Identity and Culture, Module B Close Study of Literature, Module C Craft of Writing. One-on-one support for essays and exam technique.',
            href: baseUrl('/subjects/english-standard'),
            badge: 'HSC',
          },
          {
            title: 'English Extension 1 & 2',
            desc: 'Extension 1: Literary Worlds common module and elective study. Extension 2: Major Work creative composition, Reflection Statement, and Reflective Journal guidance.',
            href: baseUrl('/subjects/english-extension'),
            badge: 'HSC',
          },
        ].map(({ title, desc, href, badge }) => (
          <a
            href={href}
            class="group flex flex-col rounded-2xl border border-border bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="mb-4 flex items-start justify-between">
              <div class="flex size-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-bold text-primary">{badge}</span>
            </div>
            <h3 class="font-heading text-xl font-bold uppercase text-text transition-colors group-hover:text-primary">{title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
            <div class="mt-5 border-t border-border pt-4">
              <span class="text-xs font-bold text-primary group-hover:underline">View course details →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Ready to book a tutoring session?"
    description="Book your session or ask about subject availability, online tutoring, and Sydney locations."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
