---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { baseUrl } from '../../utils/url';

const description = 'Private Society and Culture tutoring in Sydney and online. PIP guidance, Social Theory, Research Methodologies, Depth Studies, and HSC exam preparation with Boldtutor.';

const socReviews = [
  {
    name: 'Debbie Morley',
    rating: 5,
    quote: "Alan has been fabulous with assisting my daughter with her Society and Culture PIP. Alan is reliable and an excellent communicator. He was able to direct and teach her the best way to complete the project and she will continue using him until her HSC is completed. I highly recommend this tutoring service and feel extremely grateful to have found Alan.",
  },
  {
    name: 'Isabella Whiteman',
    rating: 5,
    quote: "Alan was extremely useful for helping me with my society and culture personal interest project. I would highly recommend for anything PIP related!",
  },
  {
    name: 'Zohra',
    rating: 5,
    quote: "Alan is one of the few teachers who ACTUALLY knows what he's teaching. Machine-like lol 🤓",
  },
];
---

<BaseLayout title="Society and Culture" description={description}>
  <Header slot="header" />

  <Banner title="Society and Culture" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">HSC Tutoring</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Society &amp; Culture</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        Society and Culture is a senior HSC subject requiring high-quality research and writing — and finding a specialist tutor can be difficult. As one of a small number of tutors offering dedicated Society &amp; Culture support, I provide the exclusive resources and guidance you need to master the syllabus and complete a PIP you can be proud of.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $80 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $75 / hr online</span>
      </div>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- What we cover -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What we cover</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Society &amp; Culture services</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            title: 'PIP',
            desc: 'I provide a template to help get your Personal Interest Project off to a strong start. Choose between a 90-minute or two-hour session to access more PIP resources and structured guidance.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
          },
          {
            title: 'Social Theory',
            desc: 'Understand the key theories in the S&C syllabus — Marxism, Feminism, Buddhism, Christianity and more. I break down the concepts so you can apply and develop your own theoretical analysis.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
          },
          {
            title: 'Research Methodologies',
            desc: 'Starting a PIP requires the right approach. I help you work through case studies and focus groups so you can identify the best methodology for your topic and plan your project with confidence.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />',
          },
          {
            title: 'Depth Studies',
            desc: 'I help you understand course concepts, key language, and analytical frameworks for whichever social and cultural group you are studying — so you can write with clarity and depth in your HSC exam.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Boldtutor -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Why Boldtutor</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">What sets us apart</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            title: 'One-on-one sessions',
            desc: 'Every student has a unique set of challenges. Face-to-face sessions ensure each learner gets individual attention and a tailored plan — not a one-size-fits-all approach.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />',
          },
          {
            title: 'Your location or online',
            desc: "I travel to your home or any location that suits you across Sydney. Prefer remote learning? Online sessions are available too — flexible scheduling designed around your life.",
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
          },
          {
            title: 'Tailor-made guidance',
            desc: 'No two PIPs are the same. I guide each student through every aspect of their project — from topic selection to final submission — to help them achieve the best possible mark.',
            icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
          },
        ].map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="pb-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <a
          href="https://www.google.com/search?q=boldtutor+reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 hover:opacity-80 transition-opacity"
          aria-label="See all BoldTutor Google reviews"
        >
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Google Reviews</h2>
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {socReviews.map(({ name, rating, quote }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">
              &ldquo;{quote}&rdquo;
            </blockquote>

            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
                  {name.charAt(0)}
                </div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instagram Posts -->
  <section class="pb-section bg-surface" data-instagram-section>
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">On Instagram</h2>
      </div>

      <div class="flex justify-center">
        <div class="w-full max-w-sm overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media !m-0 !w-full !min-w-0"
            data-instgrm-permalink="https://www.instagram.com/p/C4MnJ2DRnwl/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Quiz promo -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="flex flex-col items-center gap-6 rounded-2xl border border-border bg-white p-8 shadow-sm text-center sm:p-10">
        <div class="flex size-14 items-center justify-center rounded-xl bg-accent/10 text-accent">
          <svg class="size-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <div>
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Practice</span>
          <h2 class="mt-1 font-heading text-h2 font-bold uppercase text-text">Test Your Knowledge</h2>
          <p class="mt-3 max-w-lg text-text-muted leading-relaxed">
            Try the interactive multiple-choice quiz based on the 2022 HSC Society and Culture exam. Instant feedback on every question.
          </p>
        </div>
        <a
          href={baseUrl('/subjects/society-and-culture-quiz')}
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-bold text-accent-fg transition-opacity hover:opacity-90"
        >
          Start Quiz — 16 Questions
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <CTA
    title="Book your session today"
    description="Need help with Society and Culture or your PIP? Book on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>

<script>
  function loadInstagramEmbed() {
    if (window.instgrm) {
      window.instgrm.Embeds.process();
    } else if (!document.getElementById('instagram-embed-js')) {
      const s = document.createElement('script');
      s.id = 'instagram-embed-js';
      s.async = true;
      s.src = 'https://www.instagram.com/embed.js';
      document.body.appendChild(s);
    }
  }

  function initLazyInstagram() {
    const section = document.querySelector('[data-instagram-section]');
    if (!section) return;
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          loadInstagramEmbed();
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );
    observer.observe(section);
  }

  initLazyInstagram();
  document.addEventListener('astro:after-swap', initLazyInstagram);
</script>
