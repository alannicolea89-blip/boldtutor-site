---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { googleReviews } from '../../data/googleReviews';
import { baseUrl } from '../../utils/url';

const description = 'Expert HSC English Advanced tutor in Sydney and online. Essay writing, Module A Textual Conversations, Module B Critical Study of Literature, Module C Craft of Writing, and Human Experiences. One-on-one sessions in Glebe, Liverpool, Mortdale and Western Sydney.';

const modules = [
  {
    title: 'Common Module: Texts and Human Experiences',
    badge: 'Paper 1',
    desc: 'Studied by all Year 12 English students, the Common Module examines how texts represent individual and collective human experience. In Paper 1 you respond to unseen stimulus texts across Section I (short answer questions worth up to five marks each) and write an extended essay response to your prescribed text in Section II. For the 2027–2030 prescription, Common Module texts include Jessica Au\'s Cold Enough for Snow, David Malouf\'s An Imaginary Life, Henry Lawson\'s selected short stories, poetry by Gwen Harwood, Rosemary Dobson, and Samuel Wagan Watson, Michael Gow\'s Away, Richard Flanagan\'s Question 7, and Rachel Perkins\'s film One Night the Moon.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'Module A: Textual Conversations',
    badge: 'Paper 2 · Section I',
    desc: 'Module A requires a comparative essay on two prescribed texts from different periods, exploring how a modern text enters into conversation with a canonical one. For the 2027–2030 prescription, text pairs include Keats and Bright Star, Mrs Dalloway and The Hours, Hamlet and Emily Dickinson\'s Complete Poems, Julius Caesar and Machiavelli\'s The Prince, Blake\'s poetry and Tokarczuk\'s Drive Your Plow Over the Bones of the Dead, and Baynton\'s Bush Studies with Cobby Eckermann\'s Inside My Mother. Sessions cover comparative essay structure, paragraph integration, and the specific techniques and contexts of your pair.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />',
  },
  {
    title: 'Module B: Critical Study of Literature',
    badge: 'Paper 2 · Section II',
    desc: 'Module B is an intensive, single-text study focused on textual integrity, cultural significance, and the sustained critical argument. For the 2027–2030 prescription, Module B texts include Jane Austen\'s Pride and Prejudice, Michael Ondaatje\'s Warlight, Shakespeare\'s Othello, Shakespeare\'s King Henry IV Part 1, Louise Glück\'s selected poems, and W.B. Yeats\'s selected poems. The key challenge is building an argument that goes beyond what the text means and instead examines how it produces meaning, why it has endured, and what it reveals when read closely.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
  },
  {
    title: 'Module C: The Craft of Writing',
    badge: 'Paper 2 · Section III',
    desc: 'Module C develops your writing by studying published models across imaginative, persuasive, and discursive forms. In the exam, you produce an original piece (or a series of shorter pieces) and a reflection statement explaining your compositional choices. The reflection statement is often underprepared, but at Advanced level it is assessed at the same standard as your creative piece, and it rewards students who can articulate precisely what effect they intended and how they achieved it. Sessions focus on both the quality of the writing itself and the analytical language needed to write a high-scoring reflection.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />',
  },
];

const whatICover = [
  {
    title: 'Essay Writing and Argument',
    desc: 'Every module in English Advanced rewards students who can construct a clear, sustained argument and develop it across a full essay. Sessions target the specific writing gaps that are costing you marks: thesis construction, paragraph structure, integration of textual evidence, and the precision of your expression. We work with your actual essays, not generic templates.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />',
  },
  {
    title: 'Prescribed Text Preparation',
    desc: 'Your prescribed texts change the nature of what each module demands. We provide tailored analysis, contextual notes, and structured essay preparation for your school\'s specific texts across all four modules — whether that is W.B. Yeats or Louise Glück for Module B, Keats and Bright Star or Hamlet and Dickinson for Module A, or Gwen Harwood and David Malouf for the Common Module. Resources are adapted to your actual assessment tasks.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  },
  {
    title: 'Craft of Writing and Exam Technique',
    desc: 'Module C creative writing is assessed alongside a reflection statement, and both need to be prepared strategically. Sessions work through published models, develop your writing voice, and build the analytical vocabulary needed for a strong reflection. For Paper 1 and Paper 2, we also work on time management and exam strategy so you arrive knowing exactly how to allocate your effort.',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  },
];

const textsTeaching = [
  // Common Module — 2027–2030 prescription
  'Jessica Au — Cold Enough for Snow (Common Module)',
  'David Malouf — An Imaginary Life (Common Module)',
  'Henry Lawson — Selected Short Stories (Common Module)',
  'Gwen Harwood — Selected Poems (Common Module)',
  'Rosemary Dobson — Selected Poems (Common Module)',
  'Samuel Wagan Watson — Love Poems and Death Threats (Common Module)',
  'Michael Gow — Away (Common Module)',
  'Richard Flanagan — Question 7 (Common Module)',
  'Rachel Perkins — One Night the Moon (Common Module)',
  // Module A — Textual Conversations pairings
  'Keats — Selected Odes / Jane Campion — Bright Star (Module A)',
  'Virginia Woolf — Mrs Dalloway / Stephen Daldry — The Hours (Module A)',
  'Shakespeare — Hamlet / Emily Dickinson — Complete Poems (Module A)',
  'Shakespeare — Julius Caesar / Machiavelli — The Prince (Module A)',
  'William Blake — Poetry / Olga Tokarczuk — Drive Your Plow Over the Bones of the Dead (Module A)',
  'Barbara Baynton — Bush Studies / Ali Cobby Eckermann — Inside My Mother (Module A)',
  // Module B — Critical Study of Literature
  'Jane Austen — Pride and Prejudice (Module B)',
  'Michael Ondaatje — Warlight (Module B)',
  'Shakespeare — Othello (Module B)',
  'Shakespeare — King Henry IV, Part 1 (Module B)',
  'Louise Glück — Selected Poems (Module B)',
  'W.B. Yeats — Selected Poems (Module B)',
];

const blogResources = [
  {
    title: 'Module A: Essay Structure for Textual Conversations',
    href: baseUrl('/blog/module-a-textual-conversations-tempest-hag-seed'),
    tag: 'Module A',
  },
  {
    title: 'Module A: How to Build Your Body Paragraphs',
    href: baseUrl('/blog/module-a-textual-conversations-paragraph-structure'),
    tag: 'Module A',
  },
  {
    title: 'T.S. Eliot — Preludes: Stanza-by-Stanza Analysis',
    href: baseUrl('/blog/ts-eliot-preludes-critical-study-analysis'),
    tag: 'Module B',
  },
  {
    title: 'T.S. Eliot — Prufrock: Analysis for HSC English Advanced',
    href: baseUrl('/blog/ts-eliot-prufrock-critical-study-analysis'),
    tag: 'Module B',
  },
  {
    title: 'T.S. Eliot — The Hollow Men: Analysis for HSC English Advanced',
    href: baseUrl('/blog/ts-eliot-hollow-men-critical-study-analysis'),
    tag: 'Module B',
  },
  {
    title: 'HSC English Advanced Section I: Human Experiences Short Answers',
    href: baseUrl('/blog/hsc-english-advanced-section-i-human-experiences-short-answers'),
    tag: 'Common Module',
  },
  {
    title: '1984 — George Orwell: Techniques and Analysis',
    href: baseUrl('/blog/1984-george-orwell-techniques-and-analysis-hsc-english'),
    tag: 'Common Module',
  },
  {
    title: 'The Crucible: Human Experiences Analysis',
    href: baseUrl('/blog/the-crucible-arthur-miller-human-experiences-hsc'),
    tag: 'Common Module',
  },
  {
    title: 'Merchant of Venice: Human Experiences Essay',
    href: baseUrl('/blog/merchant-of-venice-human-experiences-hsc'),
    tag: 'Common Module',
  },
];
---

<BaseLayout
  title="English Advanced Tutor Sydney"
  description={description}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'HSC English Advanced Tutoring',
    provider: { '@type': 'LocalBusiness', name: 'Boldtutor' },
    areaServed: 'Sydney',
    description: description,
  }}
>
  <Header slot="header" />

  <Banner title="HSC English Advanced" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">HSC Tutoring</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">English Advanced</h2>
      <p class="mt-4 text-text-muted leading-relaxed">
        HSC English Advanced is the course for students who want to achieve at the highest level. It demands strong writing skills, detailed textual knowledge across four distinct modules, and the ability to construct sophisticated analytical arguments under timed exam conditions.
      </p>
      <p class="mt-3 text-text-muted leading-relaxed">
        The course is built around four Year 12 modules: Texts and Human Experiences (Common Module), Textual Conversations (Module A), Critical Study of Literature (Module B), and The Craft of Writing (Module C). Each module requires a different kind of writing, a different relationship with your prescribed text, and different preparation. What they share is the need for close, precise textual analysis and an argument that goes beyond summary.
      </p>
      <p class="mt-3 text-text-muted leading-relaxed">
        I provide one-on-one tutoring across all four modules, tailored to your school's specific prescribed texts. Whether you are working on essay structure, deepening your analysis of a prescribed text, or developing your creative writing for Module C, sessions are focused on the skills you need and the assessment you have coming up.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $65 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $55 / hr online</span>
      </div>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Modules -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">The Course</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Year 12 Modules</h2>
        <p class="mt-3 text-text-muted leading-relaxed">English Advanced has four HSC-assessed modules. Each appears in either Paper 1 or Paper 2 of the final exam.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        {modules.map(({ title, badge, desc, icon }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-4 flex items-start justify-between gap-3">
              <div class="flex size-11 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
              </div>
              <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-bold text-primary">{badge}</span>
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What I cover -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">What we cover</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">English Advanced tutoring</h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        {whatICover.map(({ title, desc, icon }) => (
          <div class="flex gap-5 rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex size-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icon} />
            </div>
            <div>
              <h3 class="font-heading text-base font-bold uppercase text-text">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Texts we cover -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">2027–2030 Prescription</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Texts that we cover</h2>
        <p class="mt-3 text-text-muted leading-relaxed">All texts below are from the new 2027–2030 NESA prescription. If your school's text is not listed, get in touch — resources are available across a wide range of Advanced texts.</p>
      </div>
      <div class="mx-auto max-w-2xl">
        <ul class="grid gap-3 sm:grid-cols-2">
          {textsTeaching.map((text) => (
            <li class="flex items-start gap-3 rounded-lg border border-border bg-white px-4 py-3 text-sm text-text shadow-sm">
              <svg class="mt-0.5 size-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {text}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Blog Resources -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Free Resources</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Study guides &amp; analysis</h2>
        <p class="mt-3 text-text-muted leading-relaxed">Free module guides, essay resources and text analysis for HSC English Advanced students.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {blogResources.map(({ title, href, tag }) => (
          <a
            href={href}
            class="group flex items-start gap-3 rounded-xl border border-border bg-white p-4 shadow-sm transition-shadow hover:shadow-md"
          >
            <svg class="mt-0.5 size-5 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <div>
              <span class="mb-1 inline-block rounded-full bg-primary/10 px-2 py-0.5 text-xs font-bold text-primary">{tag}</span>
              <p class="text-sm font-semibold text-text transition-colors group-hover:text-primary">{title}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="pb-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <a
          href="https://www.google.com/search?q=boldtutor+reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 hover:opacity-80 transition-opacity"
          aria-label="See all Boldtutor Google reviews"
        >
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Google Reviews</h2>
          <span class="mt-0.5 block text-xs text-text-muted">57 reviews · 5.0 ★ — view all on Google ↗</span>
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {googleReviews.map(({ name, rating, quote }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">&ldquo;{quote}&rdquo;</blockquote>
            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">{name.charAt(0)}</div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Book your English Advanced session today"
    description="Need help with essays, module analysis, or exam preparation for HSC English Advanced? Book on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
