---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { baseUrl } from '../utils/url';

const faqs = [
  {
    question: 'What services does Boldtutor provide?',
    answer: `As Boldtutor’s founder, I Alan Roger Nicolea, offer private tutor services to secondary (yr 7-12), university and primary students. I offer assistance with English year 7-11, English Advanced, English Standard, English Extension and HSIE subjects such as History, Modern History and Society and Culture. I also offers assistance with university subjects based on Bachelor of Arts/ humanities/politics and/or international studies, Bachelor of Education and other courses. Tuition at Primary school level is also offered. If you need help with a specific area or topic, or have any other questions, just visit my contact page and fill out the form.`,
  },
  {
    question: 'What qualifications does Boldtutor possess?',
    answer: `I founded Boldtutor in 2016 and tutor many clients ranging from Primary school all the way to University clients. I possess a University degree (Bachelor of Arts) and finished with a GPA of 5.50. I have also undergone the Working with Children check (paid positions). You can also check out our <a href="https://www.google.com/search?q=boldtutor+reviews" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:opacity-80">Google Reviews</a>.`,
  },
  {
    question: 'Where is Boldtutor based?',
    answer: `Boldtutor is primarily based in the Greater Liverpool area (Western Sydney) on Monday, Friday, Saturday and Sunday, and Mortdale on Tuesday, Wednesday and Thursday. Face-to-face English tutoring and HSC tutor sessions are available across Sydney including Glebe, Liverpool, Mortdale, and surrounding Western Sydney areas. Online English tutoring is available Australia-wide via Zoom.`,
  },
];
---

<BaseLayout title="FAQs" description="Frequently asked questions about Boldtutor tutoring services, qualifications, locations, and payments.">
  <Header slot="header" />

  <Banner title="FAQs" />

  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="space-y-4">
        {faqs.map(({ question, answer }, index) => (
          <details class="rounded-lg border border-border bg-background p-5 shadow-sm" open={index === 0}>
            <summary class="cursor-pointer list-none font-heading text-xl font-semibold text-text">
              {question}
            </summary>
            <p class="mt-4 leading-relaxed text-text-muted" set:html={answer} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Still have questions?"
    description="Ask about subjects, locations, and session options on WhatsApp."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
