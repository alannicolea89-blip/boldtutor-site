---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { googleReviews } from '../data/googleReviews';
import { baseUrl } from '../utils/url';

const title = 'HSC English Tutor in Liverpool';
const description = 'Private HSC English tutor in Liverpool and South West Sydney. Face-to-face sessions Monday, Friday, Saturday and Sunday. Serving Liverpool, Casula, Edmondson Park, Hoxton Park, Cabramatta and the Macarthur area. English Advanced, Standard, Extension, Society and Culture, Modern History.';

const schools = [
  { name: 'Thomas Hassall Anglican College', suburb: 'Cobbitty / Narellan' },
  { name: 'Macarthur Anglican School', suburb: 'Cobbitty' },
  { name: 'St Francis Catholic College', suburb: 'Edmondson Park' },
  { name: 'Clancy Catholic College', suburb: 'West Hoxton' },
  { name: 'All Saints Catholic College', suburb: 'Liverpool' },
  { name: 'Georges River Grammar', suburb: 'Peakhurst' },
];

const coverageSuburbs = [
  'Liverpool', 'Casula', 'Moorebank', 'Warwick Farm', 'Cabramatta',
  'Fairfield', 'Lurnea', 'Miller', 'Sadleir', 'Cartwright',
  'Hoxton Park', 'West Hoxton', 'Cecil Hills', 'Edmondson Park',
  'Prestons', 'Hinchinbrook', 'Middleton Grange',
];

const subjects = [
  { label: 'HSC English Advanced' },
  { label: 'HSC English Standard' },
  { label: 'HSC English Extension 1 & 2' },
  { label: 'Society and Culture (PIP)' },
  { label: 'Modern History' },
  { label: 'High School English Years 7–11' },
  { label: 'NAPLAN Preparation' },
  { label: 'Online Tutoring — Australia-wide' },
];

const faqs = [
  {
    question: 'Do you offer face-to-face HSC tutoring in Liverpool on weekends?',
    answer: 'Yes. Face-to-face sessions in Liverpool and South West Sydney are available on Monday, Friday, Saturday, and Sunday. Weekend availability is particularly useful for students whose school and extracurricular commitments fill weekdays.',
  },
  {
    question: 'Which schools in the Liverpool and Macarthur area do you support?',
    answer: 'I have tutored students from Thomas Hassall Anglican College, Macarthur Anglican School, St Francis Catholic College (Edmondson Park), Clancy Catholic College (West Hoxton), All Saints Catholic College, and Georges River Grammar, among others across the South West Sydney area.',
  },
  {
    question: 'Do you travel to students in Casula, Edmondson Park, or Cabramatta?',
    answer: 'Yes. I travel to students\' homes and preferred locations across the Liverpool LGA and surrounding areas including Casula, Moorebank, Edmondson Park, West Hoxton, Cabramatta, Fairfield, and other suburbs listed above. Contact me via WhatsApp to confirm your suburb.',
  },
  {
    question: 'Can you help with HSC English and Society and Culture in South West Sydney?',
    answer: 'Yes. All HSC subjects are available: English Advanced, Standard, Extension 1 and 2, Society and Culture including PIP support, Modern History, and high school English for Years 7 to 11. Society and Culture PIP tutoring is available to students at Thomas Hassall, Macarthur Anglican, and other schools in the area.',
  },
  {
    question: 'Is online tutoring available for Liverpool students?',
    answer: 'Yes. Online sessions via Zoom are available every day of the week, including days when face-to-face sessions are not scheduled. Online tutoring is offered from $55 per hour and is suitable for students who prefer to study from home or who live further from Liverpool.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': ['LocalBusiness', 'EducationalOrganization'],
        name: 'Boldtutor',
        telephone: '+61416419270',
        email: 'contact@boldtutor.com.au',
        url: 'https://boldtutor.com.au',
        areaServed: [
          { '@type': 'City', name: 'Liverpool' },
          { '@type': 'City', name: 'Casula' },
          { '@type': 'City', name: 'Edmondson Park' },
          { '@type': 'City', name: 'Cabramatta' },
          { '@type': 'City', name: 'Fairfield' },
          { '@type': 'City', name: 'Campbelltown' },
        ],
      },
      {
        '@type': 'FAQPage',
        mainEntity: faqs.map(({ question, answer }) => ({
          '@type': 'Question',
          name: question,
          acceptedAnswer: { '@type': 'Answer', text: answer },
        })),
      },
    ],
  }}
>
  <Header slot="header" />

  <Banner title="HSC Tutor Liverpool" />

  <!-- Intro -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">Face-to-face · Mon, Fri, Sat, Sun</span>
      <h1 class="mt-2 font-heading text-h2 font-bold uppercase text-text">HSC English Tutor in Liverpool</h1>
      <p class="mt-4 text-text-muted leading-relaxed">
        Liverpool is one of the fastest-growing areas in NSW and home to a large and diverse student population. The South West Sydney corridor — from Liverpool through to the Macarthur area — includes some of the state's most respected Anglican and Catholic schools, many of which send students into competitive HSC cohorts each year.
      </p>
      <p class="mt-3 text-text-muted leading-relaxed">
        Face-to-face tutoring sessions are available in Liverpool and surrounding suburbs on Monday, Friday, Saturday, and Sunday. I travel to your home or a location convenient to you — whether that is a local library, a café, or another quiet space. Weekend availability means students with full school timetables during the week do not need to miss out on regular tutoring support.
      </p>
      <p class="mt-3 text-text-muted leading-relaxed">
        Sessions cover HSC English Advanced, Standard, and Extension, Society and Culture including PIP, Modern History, high school English for Years 7 to 11, and NAPLAN. Online tutoring via Zoom is also available on all days of the week.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3 text-sm font-semibold text-accent">
        <span>From $65 / hr face-to-face</span>
        <span class="text-border">·</span>
        <span>From $55 / hr online</span>
      </div>
      <a
        href="https://wa.me/61416419270"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-primary-fg transition-opacity hover:opacity-90"
      >
        Book your free 1hr session
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Schools and Areas -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid gap-10 lg:grid-cols-2">

        <div>
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Schools</span>
          <h2 class="mt-1 font-heading text-h2 font-bold uppercase text-text">Schools we support</h2>
          <p class="mt-3 mb-5 text-sm leading-relaxed text-text-muted">Students currently or previously tutored from schools in the Liverpool, South West Sydney and Macarthur area:</p>
          <ul class="space-y-2">
            {schools.map(({ name, suburb }) => (
              <li class="flex items-start gap-3 rounded-lg border border-border bg-white px-4 py-3 text-sm shadow-sm">
                <svg class="mt-0.5 size-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>
                  <span class="font-semibold text-text">{name}</span>
                  <span class="ml-1.5 text-text-muted">— {suburb}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Coverage</span>
          <h2 class="mt-1 font-heading text-h2 font-bold uppercase text-text">Areas covered</h2>
          <p class="mt-3 mb-5 text-sm leading-relaxed text-text-muted">Face-to-face sessions available across the following suburbs on Monday, Friday, Saturday, and Sunday:</p>
          <div class="flex flex-wrap gap-2">
            {coverageSuburbs.map((suburb) => (
              <span class="rounded-full border border-border bg-white px-3 py-1 text-sm text-text shadow-sm">{suburb}</span>
            ))}
          </div>
          <p class="mt-5 text-sm leading-relaxed text-text-muted">
            Also accessible from Liverpool: the Macarthur area including Campbelltown, Narellan, and Camden. Contact me via WhatsApp to confirm availability in your specific suburb.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Subjects -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-8 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">Services</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Subjects available in Liverpool</h2>
        <p class="mt-3 text-text-muted text-sm leading-relaxed">All of the following are available face-to-face in Liverpool and South West Sydney, and online Australia-wide.</p>
      </div>
      <div class="mx-auto max-w-2xl">
        <ul class="grid gap-3 sm:grid-cols-2">
          {subjects.map(({ label }) => (
            <li class="flex items-center gap-3 rounded-lg border border-border bg-white px-4 py-3 text-sm font-medium text-text shadow-sm">
              <svg class="size-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {label}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="py-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mb-5 flex items-center gap-3">
        <a href="https://www.google.com/search?q=boldtutor+reviews" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 hover:opacity-80 transition-opacity" aria-label="See all Boldtutor Google reviews">
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h2 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Google Reviews</h2>
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {googleReviews.map(({ name, rating, quote }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">&ldquo;{quote}&rdquo;</blockquote>
            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">{name.charAt(0)}</div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="mb-8 text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-accent">FAQ</span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Common questions</h2>
      </div>
      <div class="space-y-3">
        {faqs.map(({ question, answer }, i) => (
          <details class="rounded-lg border border-border bg-white p-5 shadow-sm" open={i === 0}>
            <summary class="cursor-pointer list-none font-heading text-base font-semibold text-text">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="pb-section bg-surface">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="overflow-hidden rounded-2xl border border-border shadow-sm">
        <iframe
          src="https://maps.google.com/maps?q=Liverpool+NSW+2170&t=&z=13&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="320"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Liverpool NSW tutoring area map"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Internal links -->
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-2">
        <div>
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Subjects</span>
          <h2 class="mt-1 font-heading text-h2 font-bold uppercase text-text">Subject pages</h2>
          <ul class="mt-4 space-y-2">
            {[
              { label: 'HSC English Advanced', href: '/subjects/english-advanced' },
              { label: 'HSC English Standard', href: '/subjects/english-standard' },
              { label: 'HSC English Extension', href: '/subjects/english-extension' },
              { label: 'Society & Culture', href: '/subjects/society-and-culture' },
              { label: 'Modern History', href: '/subjects/modern-history' },
            ].map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm font-medium text-primary hover:underline">{label} →</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <span class="text-topper font-bold uppercase tracking-widest text-accent">Other areas</span>
          <h2 class="mt-1 font-heading text-h2 font-bold uppercase text-text">Also serving</h2>
          <ul class="mt-4 space-y-2">
            {[
              { label: 'Mortdale & St George', href: '/hsc-tutor-mortdale' },
              { label: 'Western Sydney', href: '/hsc-tutor-western-sydney' },
              { label: 'Glebe & Inner West', href: '/english-tutor-glebe' },
              { label: 'North Shore', href: '/hsc-tutor-north-shore' },
            ].map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm font-medium text-primary hover:underline">{label} →</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="Book your Liverpool tutoring session"
    description="Face-to-face in Liverpool and South West Sydney on Monday, Friday, Saturday, and Sunday. Online available every day."
    buttonText="Book Your free 1hr Session Now"
    buttonHref="https://wa.me/61416419270"
  />

  <Footer slot="footer" />
</BaseLayout>
