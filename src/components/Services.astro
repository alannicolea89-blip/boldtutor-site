---
type IconKey = 'book' | 'graduation' | 'history' | 'society' | 'default';

interface ServiceItem {
  title: string;
  description: string;
  points?: string[];
  icon?: IconKey;
  backgroundIcon?: IconKey;
  backgroundImage?: string;
  href?: string;
}

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  services?: ServiceItem[];
}

const iconPaths: Record<IconKey, string> = {
  default: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  book: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />',
  graduation: '<path d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />',
  history: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
  society: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />',
};

const fallbackIcons: IconKey[] = ['default', 'default', 'default', 'default', 'default', 'default'];

const {
  topper = 'What We Do',
  heading = 'Our Services',
  description = 'From routine maintenance to complex projects, we deliver quality workmanship with honest pricing.',
  services = [
    { title: 'General Repairs',      description: 'Reliable fixes for plumbing, electrical, drywall, and more — done right the first time.', href: '/services' },
    { title: 'Installations',        description: 'Professional installation of fixtures, appliances, and systems with clean, code-compliant results.', href: '/services' },
    { title: 'Inspections',          description: 'Thorough property inspections to catch issues before they become costly problems.', href: '/services' },
    { title: 'Remodeling',           description: 'Transform kitchens, bathrooms, and living spaces with expert craftsmanship and attention to detail.', href: '/services' },
    { title: 'Emergency Service',    description: '24/7 emergency response when you need help fast — we\'re just a phone call away.', href: '/services' },
    { title: 'Maintenance Plans',    description: 'Scheduled preventive maintenance to protect your property and avoid surprise repair bills.', href: '/services' },
  ],
} = Astro.props;
---

<section class="bg-surface py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">{heading}</h2>
      <p class="mt-3 text-text-muted leading-relaxed">{description}</p>
    </div>

    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {services.map((service, i) => {
        const iconKey = service.icon ?? fallbackIcons[i % fallbackIcons.length];
        const iconPath = iconPaths[iconKey] ?? iconPaths.default;
        const backgroundIconKey = service.backgroundIcon;
        const backgroundIconPath = backgroundIconKey ? iconPaths[backgroundIconKey] : undefined;
        return (
        <li>
          <a
            href={service.href || '/services'}
            aria-label={`Learn more about ${service.title}`}
            class="group relative flex h-full cursor-pointer flex-col overflow-hidden rounded-lg border border-border bg-background p-6 shadow-sm transition-shadow duration-200 hover:shadow-md"
          >
            {service.backgroundImage && (
              <>
                <div class="pointer-events-none absolute inset-0 bg-linear-to-r from-background via-background/92 to-background/65" aria-hidden="true" />
                <div class="pointer-events-none absolute right-5 top-5 overflow-hidden rounded-2xl border border-primary/10 bg-surface/70 shadow-sm backdrop-blur-[1px]" aria-hidden="true">
                  <img
                    src={service.backgroundImage}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="h-36 w-28 object-cover sepia grayscale contrast-125 opacity-[0.28] transition-opacity group-hover:opacity-[0.38]"
                  />
                  <div class="absolute inset-0 bg-linear-to-t from-background/55 via-transparent to-background/15" />
                </div>
              </>
            )}
            {backgroundIconPath && (
              <div class="pointer-events-none absolute -bottom-6 -right-6 text-primary/10 transition-colors group-hover:text-primary/15" aria-hidden="true">
                <svg class="size-36" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={backgroundIconPath} />
              </div>
            )}
            <div class="relative z-10 mb-4 flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-fg">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={iconPath} />
            </div>
            <h3 class="relative z-10 font-heading text-h3 font-semibold text-text">{service.title}</h3>
            {service.points?.length ? (
              <ul class="relative z-10 mt-2 flex-1 list-disc space-y-1 pl-5 text-sm leading-relaxed text-text-muted">
                {service.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            ) : (
              <p class="relative z-10 mt-2 flex-1 text-sm leading-relaxed text-text-muted">{service.description}</p>
            )}
            <span class="relative z-10 mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors group-hover:text-accent">
              Learn more
              <span class="sr-only"> about {service.title}</span>
              <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        </li>
        );
      })}
    </ul>
  </div>
</section>
