---
import { googleReviews } from '../data/googleReviews';

interface Props {
  ctaLabel?: string;
  ctaHref?: string;
}

const { ctaLabel = 'Contact Us', ctaHref = '/contact' } = Astro.props;
---

<section class="py-section bg-surface">
  <div class="mx-auto max-w-site px-4 sm:px-6">

    <!-- Section header -->
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">Student Results</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Samples of success</h2>
      <p class="mt-3 text-text-muted leading-relaxed">
        Scroll through examples and outcomes, then book your session today.
      </p>
    </div>

    <!-- Google Reviews -->
    <div class="mb-12">
      <div class="mb-5 flex items-center gap-3">
        <a
          href="https://www.google.com/search?q=boldtutor+reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 hover:opacity-80 transition-opacity"
          aria-label="See all BoldTutor Google reviews"
        >
          <!-- Google "G" logo -->
          <svg class="size-6 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <h3 class="font-heading text-lg font-bold uppercase tracking-wide text-text">Google Reviews</h3>
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {googleReviews.map(({ name, rating, quote }) => (
          <div class="flex flex-col rounded-xl border border-border bg-white p-6 shadow-sm">
            <!-- Stars -->
            <div class="mb-3 flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
              {Array.from({ length: rating }).map(() => (
                <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="flex-1 text-sm leading-relaxed text-text-muted">
              &ldquo;{quote}&rdquo;
            </blockquote>

            <!-- Reviewer -->
            <div class="mt-5 flex items-center justify-between border-t border-border pt-4">
              <div class="flex items-center gap-2.5">
                <div class="flex size-8 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
                  {name.charAt(0)}
                </div>
                <span class="text-sm font-semibold text-text">{name}</span>
              </div>
              <span class="text-xs text-text-muted">Google Review</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Instagram Posts -->
    <div class="mb-10">
      <div class="mb-5 flex items-center gap-3">
        <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        <h3 class="font-heading text-lg font-bold uppercase tracking-wide text-text">On Instagram</h3>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media !m-0 !w-full !min-w-0"
            data-instgrm-permalink="https://www.instagram.com/p/DFwD1AizEFz/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media !m-0 !w-full !min-w-0"
            data-instgrm-permalink="https://www.instagram.com/p/C_ht1KeRq6O/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
        <div class="overflow-hidden rounded-xl">
          <blockquote
            class="instagram-media !m-0 !w-full !min-w-0"
            data-instgrm-permalink="https://www.instagram.com/p/C_MRtx9SItB/"
            data-instgrm-version="14"
          ></blockquote>
        </div>
      </div>
    </div>

    <!-- CTA -->
    {ctaLabel && (
      <div class="text-center">
        <a
          href={ctaHref}
          class="inline-flex min-h-11 items-center gap-2 rounded-md border-2 border-primary px-6 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg"
        >
          {ctaLabel}
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}

  </div>
</section>

<script>
  // Load Instagram embed.js and re-process on view-transition navigation
  function loadInstagramEmbed() {
    if (window.instgrm) {
      window.instgrm.Embeds.process();
    } else if (!document.getElementById('instagram-embed-js')) {
      const s = document.createElement('script');
      s.id = 'instagram-embed-js';
      s.async = true;
      s.src = 'https://www.instagram.com/embed.js';
      document.body.appendChild(s);
    }
  }
  loadInstagramEmbed();
  document.addEventListener('astro:after-swap', loadInstagramEmbed);
</script>
