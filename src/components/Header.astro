---
import { brand } from '../config/brand';
import { client } from '../data/client';
import { baseUrl } from '../utils/url';

type Child = { label: string; href: string };
type NavItem =
  | { label: string; href: string; children?: never }
  | { label: string; href: string; children: Child[] };

const nav: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  {
    label: 'Subjects',
    href: '/subjects',
    children: [
      { label: 'Primary School English (Yr 3–6)', href: '/subjects/primary-school-english' },
      { label: 'High School English (Yr 7–11)',   href: '/prices/english-yr7-11' },
      { label: 'HSC English Advanced',             href: '/subjects/english-advanced' },
      { label: 'HSC English Standard',             href: '/subjects/english-standard' },
      { label: 'HSC English Extension',            href: '/subjects/english-extension' },
      { label: 'Modern History',                   href: '/subjects/modern-history' },
      { label: 'Society & Culture',                href: '/subjects/society-and-culture' },
    ],
  },
  { label: 'Prices/Offers', href: '/prices' },
  { label: 'FAQs',          href: '/faqs' },
  { label: 'Blog',          href: '/blog' },
  { label: 'Quizzes',       href: '/quizzes' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  currentPath === baseUrl(href) || (href !== '/' && currentPath.startsWith(baseUrl(href)));

const isGroupActive = (item: NavItem) =>
  isActive(item.href) || (item.children?.some(c => isActive(c.href)) ?? false);
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm"
  transition:persist
>
  <div class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6">

    <!-- Logo -->
    <a
      href={baseUrl('/')}
      class="inline-flex items-center transition-opacity hover:opacity-80"
      aria-label={`${brand.name} home`}
    >
      <img
        src={baseUrl('/images/newlog.jpeg')}
        alt={`${brand.name} logo`}
        class="h-14 w-auto sm:h-16"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
      {nav.map((item) => {
        if (!item.children) {
          const active = isActive(item.href);
          return (
            <a
              href={baseUrl(item.href)}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                active ? 'bg-primary/10 text-primary' : 'text-text-muted hover:text-text',
              ]}
            >
              {item.label}
            </a>
          );
        }

        const active = isGroupActive(item);
        return (
          <div class="relative" data-dropdown>
            <button
              type="button"
              aria-expanded="false"
              aria-haspopup="menu"
              data-dropdown-trigger
              class:list={[
                'flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium transition-colors',
                active ? 'bg-primary/10 text-primary' : 'text-text-muted hover:text-text',
              ]}
            >
              {item.label}
              <svg
                data-dropdown-chevron
                class="size-4 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div
              role="menu"
              data-dropdown-menu
              class="absolute left-0 top-full z-50 mt-1 hidden w-60 rounded-xl border border-border bg-white py-1.5 shadow-lg"
            >
              <a
                href={baseUrl(item.href)}
                role="menuitem"
                class="flex items-center gap-2 px-4 py-2 text-xs font-bold uppercase tracking-widest text-accent hover:bg-surface"
              >
                All Subjects →
              </a>
              <div class="my-1 border-t border-border" role="separator" />
              {item.children.map((child) => {
                const childActive = isActive(child.href);
                return (
                  <a
                    href={baseUrl(child.href)}
                    role="menuitem"
                    class:list={[
                      'block px-4 py-2.5 text-sm transition-colors',
                      childActive
                        ? 'bg-primary/10 font-semibold text-primary'
                        : 'text-text hover:bg-surface hover:text-primary',
                    ]}
                  >
                    {child.label}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </nav>

    <!-- Desktop CTA + phone -->
    <div class="hidden items-center gap-4 lg:flex">
      {client.license && (
        <span class="rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-muted">
          {client.license}
        </span>
      )}
      <a
        href={`tel:${client.phoneForTel}`}
        class="text-sm font-semibold text-text hover:text-primary transition-colors"
      >
        {client.phoneFormatted}
      </a>
      <a
        href="https://wa.me/61416419270"
        class="inline-flex min-h-[44px] items-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Book Your free 1hr Session Now
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex min-h-[44px] min-w-11 items-center justify-center rounded-md text-text-muted hover:bg-surface lg:hidden"
    >
      <span class="sr-only">Toggle menu</span>
      <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-background px-4 pb-6 pt-2 lg:hidden"
  >
    <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
      {nav.map((item) => {
        if (!item.children) {
          const active = isActive(item.href);
          return (
            <a
              href={baseUrl(item.href)}
              class:list={[
                'rounded-md px-3 py-3 text-base font-medium transition-colors',
                active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-muted hover:bg-surface hover:text-text',
              ]}
            >
              {item.label}
            </a>
          );
        }

        const active = isGroupActive(item);
        return (
          <div data-mobile-group>
            <button
              type="button"
              aria-expanded="false"
              data-mobile-group-trigger
              class:list={[
                'flex w-full items-center justify-between rounded-md px-3 py-3 text-base font-medium transition-colors',
                active
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-muted hover:bg-surface hover:text-text',
              ]}
            >
              {item.label}
              <svg
                data-mobile-group-chevron
                class="size-4 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <div data-mobile-group-content class="hidden pl-3 pt-1">
              <a
                href={baseUrl(item.href)}
                class="block rounded-md px-3 py-2 text-sm font-bold text-accent hover:bg-surface"
              >
                All Subjects
              </a>
              {item.children.map((child) => {
                const childActive = isActive(child.href);
                return (
                  <a
                    href={baseUrl(child.href)}
                    class:list={[
                      'block rounded-md px-3 py-2.5 text-sm transition-colors',
                      childActive
                        ? 'font-semibold text-primary'
                        : 'text-text-muted hover:bg-surface hover:text-text',
                    ]}
                  >
                    {child.label}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </nav>

    <div class="mt-4 flex flex-col gap-3 border-t border-border pt-4">
      <a
        href={`tel:${client.phoneForTel}`}
        class="flex items-center gap-2 px-3 py-2 text-base font-semibold text-text"
      >
        <svg class="size-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {client.phoneFormatted}
      </a>
      <a
        href="https://wa.me/61416419270"
        class="flex min-h-[44px] items-center justify-center rounded-md bg-accent px-5 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
      >
        Book Your free 1hr Session Now
      </a>
      {client.license && (
        <p class="px-3 pt-1 text-xs text-text-muted">{client.license}</p>
      )}
    </div>
  </div>
</header>

<script>
  let _ctrl: AbortController | null = null;

  function initMenu() {
    _ctrl?.abort();
    _ctrl = new AbortController();
    const { signal } = _ctrl;

    // ── Elements ───────────────────────────────────────────────
    const headerEl   = document.querySelector('header') as HTMLElement | null;
    const btnEl      = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menuEl     = document.getElementById('mobile-menu') as HTMLElement | null;
    const iconOpen   = document.getElementById('menu-icon-open') as HTMLElement | null;
    const iconClose  = document.getElementById('menu-icon-close') as HTMLElement | null;

    if (!headerEl || !btnEl || !menuEl || !iconOpen || !iconClose) return;

    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    // ── Mobile hamburger ───────────────────────────────────────
    const setMenuOpen = (open: boolean) => {
      if (isDesktop()) open = false;
      btnEl.setAttribute('aria-expanded', String(open));
      menuEl.classList.toggle('hidden', !open);
      iconOpen.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
    };

    btnEl.addEventListener('click', () => {
      if (isDesktop()) return;
      setMenuOpen(btnEl.getAttribute('aria-expanded') !== 'true');
    }, { signal });

    // ── Mobile group accordion ─────────────────────────────────
    headerEl.querySelectorAll<HTMLElement>('[data-mobile-group]').forEach((group) => {
      const trigger  = group.querySelector<HTMLButtonElement>('[data-mobile-group-trigger]');
      const content  = group.querySelector<HTMLElement>('[data-mobile-group-content]');
      const chevron  = group.querySelector<HTMLElement>('[data-mobile-group-chevron]');
      if (!trigger || !content || !chevron) return;

      trigger.addEventListener('click', () => {
        const open = trigger.getAttribute('aria-expanded') !== 'true';
        trigger.setAttribute('aria-expanded', String(open));
        content.classList.toggle('hidden', !open);
        chevron.classList.toggle('rotate-180', open);
      }, { signal });
    });

    // ── Desktop dropdowns ──────────────────────────────────────
    const dropdowns = Array.from(
      headerEl.querySelectorAll<HTMLElement>('[data-dropdown]')
    );

    const closeAllDropdowns = (except?: HTMLElement) => {
      dropdowns.forEach((dd) => {
        if (dd === except) return;
        const t = dd.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
        const m = dd.querySelector<HTMLElement>('[data-dropdown-menu]');
        const c = dd.querySelector<HTMLElement>('[data-dropdown-chevron]');
        if (t) t.setAttribute('aria-expanded', 'false');
        if (m) m.classList.add('hidden');
        if (c) c.classList.remove('rotate-180');
      });
    };

    dropdowns.forEach((dd) => {
      const trigger = dd.querySelector<HTMLButtonElement>('[data-dropdown-trigger]');
      const menu    = dd.querySelector<HTMLElement>('[data-dropdown-menu]');
      const chevron = dd.querySelector<HTMLElement>('[data-dropdown-chevron]');
      if (!trigger || !menu || !chevron) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = trigger.getAttribute('aria-expanded') !== 'true';
        closeAllDropdowns(open ? dd : undefined);
        trigger.setAttribute('aria-expanded', String(open));
        menu.classList.toggle('hidden', !open);
        chevron.classList.toggle('rotate-180', open);
      }, { signal });

      // Close when a link inside is clicked
      menu.addEventListener('click', () => {
        trigger.setAttribute('aria-expanded', 'false');
        menu.classList.add('hidden');
        chevron.classList.remove('rotate-180');
      }, { signal });
    });

    // Close dropdowns on outside click
    document.addEventListener('click', () => closeAllDropdowns(), { signal });

    // Close dropdowns on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAllDropdowns();
    }, { signal });

    // ── Active link sync (view transitions) ────────────────────
    const syncActiveLinks = () => {
      const path = window.location.pathname;

      const allLinks = headerEl.querySelectorAll<HTMLAnchorElement>('a[href]');
      allLinks.forEach((link) => {
        const href = link.getAttribute('href') || '';
        const active = href === path || (href !== baseUrl('/') && path.startsWith(href));
        if (active) link.setAttribute('aria-current', 'page');
        else link.removeAttribute('aria-current');
      });
    };

    // ── Shared teardown on navigation ──────────────────────────
    document.addEventListener('astro:before-preparation', () => {
      setMenuOpen(false);
      closeAllDropdowns();
    }, { signal });

    window.addEventListener('resize', () => {
      setMenuOpen(false);
      closeAllDropdowns();
    }, { signal });

    setMenuOpen(false);
    syncActiveLinks();
  }

  document.addEventListener('astro:page-load', initMenu);
</script>
